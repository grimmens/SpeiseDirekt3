@page "/pos/{MenuId:guid}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using SpeiseDirekt3.Components.POS.Components
@using SpeiseDirekt.Model
@using SpeiseDirekt.ServiceInterface
@layout PosLayout
@inject ApplicationDbContext Context
@inject IOrderService OrderService
@inject IImageUploadService ImageUploadService
@inject IPosSessionService SessionService
@inject NavigationManager NavManager
@inject IJSRuntime JS
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Order - @menu?.Name</PageTitle>

<div class="flex-1 flex flex-col lg:flex-row overflow-hidden">

    <!-- ═══════════ LEFT: MENU ITEMS ═══════════ -->
    <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Top Bar -->
        <div class="flex items-center justify-between px-4 sm:px-6 py-4 bg-gray-800/60 border-b border-gray-700/50">
            <div class="flex items-center gap-3">
                <a href="/pos" class="w-10 h-10 bg-gray-700 hover:bg-gray-600 rounded-xl flex items-center justify-center transition-colors">
                    <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <div>
                    <h1 class="text-lg font-bold text-white">@menu?.Name</h1>
                    <p class="text-xs text-gray-500">Tap items to add to your order</p>
                </div>
            </div>
            <!-- Mobile cart toggle -->
            <button class="lg:hidden relative w-12 h-12 bg-amber-500 hover:bg-amber-400 rounded-xl flex items-center justify-center transition-colors"
                    @onclick="() => showMobileCart = !showMobileCart">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                @if (cart.TotalQuantity > 0)
                {
                    <span class="absolute -top-1 -right-1 w-6 h-6 bg-red-500 rounded-full text-xs font-bold text-white flex items-center justify-center">@cart.TotalQuantity</span>
                }
            </button>
        </div>

        <!-- Category Tabs -->
        <div class="flex gap-2 px-4 sm:px-6 py-3 overflow-x-auto bg-gray-800/30 border-b border-gray-700/30 scrollbar-hide">
            <button class="px-5 py-2.5 text-sm font-semibold rounded-xl whitespace-nowrap transition-all active:scale-95 @(selectedCategoryId == null ? "bg-amber-500 text-white shadow-lg shadow-amber-500/30" : "bg-gray-700/60 text-gray-400 hover:text-white hover:bg-gray-700")"
                    @onclick="() => selectedCategoryId = null">
                All Items
            </button>
            @foreach (var cat in categories)
            {
                var catId = cat.Id;
                var isActive = selectedCategoryId == catId;
                <button class="px-5 py-2.5 text-sm font-semibold rounded-xl whitespace-nowrap transition-all active:scale-95 @(isActive ? "bg-amber-500 text-white shadow-lg shadow-amber-500/30" : "bg-gray-700/60 text-gray-400 hover:text-white hover:bg-gray-700")"
                        @onclick="() => selectedCategoryId = catId">
                    @cat.Name
                </button>
            }
        </div>

        <!-- Item Grid -->
        <div class="flex-1 overflow-y-auto p-4 sm:p-6 @(cart.TotalQuantity > 0 ? "pb-24 lg:pb-6" : "")">
            @if (!initialized)
            {
                <div class="flex items-center justify-center h-full">
                    <div class="flex items-center gap-3 text-gray-400">
                        <div class="animate-spin rounded-full h-6 w-6 border-2 border-gray-600 border-t-amber-400"></div>
                        <span>Loading menu...</span>
                    </div>
                </div>
            }
            else if (!filteredItems.Any())
            {
                <div class="flex flex-col items-center justify-center h-full text-center text-gray-500">
                    <p class="text-lg">No items in this category</p>
                </div>
            }
            else
            {
            <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-4">
                @foreach (var item in filteredItems)
                {
                    var qty = cart.Items.Where(i => i.MenuItemId == item.Id).Sum(i => i.Quantity);
                    var imgUrl = ImageUploadService.GetImageUrl(item.ImagePath);
                    var hasImage = !string.IsNullOrEmpty(item.ImagePath);
                    <button class="group relative bg-gray-800 hover:bg-gray-750 rounded-2xl overflow-hidden text-left transition-all active:scale-[0.97] border border-gray-700/50 hover:border-amber-500/50 hover:shadow-lg hover:shadow-amber-500/5"
                            @onclick="() => HandleItemTap(item)">
                        @if (qty > 0)
                        {
                            <div class="absolute top-2 right-2 w-8 h-8 bg-amber-500 rounded-full flex items-center justify-center text-sm font-bold text-white shadow-lg shadow-amber-500/40 z-10">
                                @qty
                            </div>
                        }
                        @if (hasImage)
                        {
                            <div class="w-full aspect-[4/3] bg-gray-700">
                                <img src="@imgUrl" alt="@item.Name" class="w-full h-full object-cover" loading="lazy" />
                            </div>
                        }
                        <div class="p-4">
                            <p class="font-semibold text-white text-sm sm:text-base leading-tight mb-1 line-clamp-2">@item.Name</p>
                            @if (!hasImage && !string.IsNullOrEmpty(item.Description))
                            {
                                <p class="text-xs text-gray-500 line-clamp-2 mb-2">@item.Description</p>
                            }
                            <p class="text-amber-400 font-bold text-lg">@item.Price.ToString("C")</p>
                            @if (HasCombo(item.Id))
                            {
                                <div class="mt-1.5 flex items-center gap-1">
                                    <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                    </svg>
                                    <span class="text-[11px] text-orange-400 font-medium">Combo available</span>
                                </div>
                            }
                        </div>
                    </button>
                }
            </div>
            }
        </div>

        <!-- Mobile bottom bar (shows when cart has items, hidden on lg where cart panel is visible) -->
        @if (cart.TotalQuantity > 0)
        {
            <div class="lg:hidden fixed bottom-0 left-0 right-0 z-30 bg-gray-800 border-t border-gray-700 px-4 py-3 safe-area-bottom">
                <button class="w-full py-3.5 bg-gradient-to-r from-green-500 to-emerald-500 text-white font-bold rounded-2xl flex items-center justify-center gap-3 active:scale-[0.98] transition-transform shadow-lg shadow-green-500/30"
                        @onclick="() => showMobileCart = true">
                    <span class="w-7 h-7 bg-white/20 rounded-full flex items-center justify-center text-sm">@cart.TotalQuantity</span>
                    <span>View Cart</span>
                    <span>@cart.GrandTotal.ToString("C")</span>
                </button>
            </div>
        }
    </div>

    <!-- ═══════════ RIGHT: CART ═══════════ -->
    <div class="@(showMobileCart ? "fixed inset-0 z-40 lg:relative lg:inset-auto" : "hidden lg:flex") lg:flex lg:w-[400px] lg:flex-col bg-gray-800 border-l border-gray-700/50">

        <!-- Mobile backdrop -->
        @if (showMobileCart)
        {
            <div class="lg:hidden fixed inset-0 bg-black/60" @onclick="() => showMobileCart = false"></div>
        }

        <!-- Cart panel -->
        <div class="relative z-10 flex flex-col h-full bg-gray-800 @(showMobileCart ? "ml-auto w-[85vw] max-w-[400px]" : "")">

            <!-- Cart Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-700/50">
                <div>
                    <h2 class="text-lg font-bold text-white">Your Order</h2>
                    <p class="text-xs text-gray-500">@cart.TotalQuantity items</p>
                </div>
                <div class="flex items-center gap-2">
                    @if (cart.Items.Any())
                    {
                        <button class="text-xs text-red-400 hover:text-red-300 font-medium transition-colors"
                                @onclick="ClearCart">Clear All</button>
                    }
                    <button class="lg:hidden w-10 h-10 bg-gray-700 hover:bg-gray-600 rounded-xl flex items-center justify-center transition-colors"
                            @onclick="() => showMobileCart = false">
                        <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Cart Items -->
            <div class="flex-1 overflow-y-auto">
                @if (cart.Items.Any())
                {
                    <div class="divide-y divide-gray-700/40">
                        @{ var rendered = new HashSet<int>(); }
                        @for (var idx = 0; idx < cart.Items.Count; idx++)
                        {
                            if (rendered.Contains(idx)) continue;
                            rendered.Add(idx);
                            var cartItem = cart.Items[idx];
                            var itemIdx = idx;

                            @if (cartItem.ComboId.HasValue && cartItem.IsComboTrigger)
                            {
                                // ── Combo group ──
                                var comboId = cartItem.ComboId.Value;
                                var subItems = new List<PosCartItem>();
                                for (var j = idx + 1; j < cart.Items.Count; j++)
                                {
                                    if (cart.Items[j].ComboId == comboId && !cart.Items[j].IsComboTrigger)
                                    {
                                        subItems.Add(cart.Items[j]);
                                        rendered.Add(j);
                                    }
                                }
                                var comboTotal = cartItem.LineTotal + subItems.Sum(s => s.LineTotal);

                                <div class="px-6 py-4">
                                    <!-- Combo header (tappable to edit quantity or remove) -->
                                    <button class="w-full flex items-center gap-3 hover:bg-gray-700/30 rounded-xl -mx-2 px-2 py-1 transition-colors text-left"
                                            @onclick="() => OpenComboDetail(itemIdx)">
                                        <div class="w-9 h-9 bg-amber-500 rounded-xl flex items-center justify-center flex-shrink-0">
                                            <span class="text-sm font-bold text-white">@cartItem.Quantity</span>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-medium text-white truncate">@cartItem.Name</p>
                                            <span class="text-[10px] px-1.5 py-0.5 bg-amber-500/20 text-amber-400 rounded-full font-semibold">COMBO</span>
                                        </div>
                                        <span class="text-sm font-semibold text-amber-400">@comboTotal.ToString("C")</span>
                                    </button>
                                    <!-- Sub-items (not individually editable) -->
                                    <div class="ml-12 mt-2 space-y-1.5 border-l-2 border-gray-700 pl-3">
                                        @foreach (var sub in subItems)
                                        {
                                            <div class="flex items-center justify-between">
                                                <p class="text-xs text-gray-400">@sub.Name</p>
                                                @if (sub.UnitPrice > 0)
                                                {
                                                    <span class="text-xs text-gray-500">@sub.UnitPrice.ToString("C")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-xs text-green-500">included</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else if (!cartItem.ComboId.HasValue)
                            {
                                // ── Regular item (tappable to edit quantity) ──
                                <button class="w-full px-6 py-4 flex items-center gap-3 hover:bg-gray-700/30 transition-colors text-left"
                                        @onclick="() => OpenItemDetail(itemIdx)">
                                    <div class="w-9 h-9 bg-gray-700 rounded-xl flex items-center justify-center flex-shrink-0">
                                        <span class="text-sm font-bold text-white">@cartItem.Quantity</span>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-white truncate">@cartItem.Name</p>
                                        <p class="text-xs text-gray-500">@cartItem.UnitPrice.ToString("C") each</p>
                                    </div>
                                    <span class="text-sm font-semibold text-white">@cartItem.LineTotal.ToString("C")</span>
                                </button>
                            }
                        }
                    </div>
                }
                else
                {
                    <div class="flex flex-col items-center justify-center h-full text-center px-8">
                        <div class="w-16 h-16 bg-gray-700/50 rounded-2xl flex items-center justify-center mb-4">
                            <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                        </div>
                        <p class="text-gray-500 text-sm">Your cart is empty</p>
                        <p class="text-gray-600 text-xs mt-1">Tap items on the left to add them</p>
                    </div>
                }
            </div>

            <!-- Totals + Checkout -->
            @if (cart.Items.Any())
            {
                <div class="border-t border-gray-700/50 bg-gray-800">
                    <div class="px-6 py-4 space-y-1.5">
                        <div class="flex justify-between text-sm text-gray-500">
                            <span>Subtotal</span>
                            <span>@cart.SubTotal.ToString("C")</span>
                        </div>
                        <div class="flex justify-between text-sm text-gray-500">
                            <span>Tax (@((defaultTaxRate * 100).ToString("0.##"))%)</span>
                            <span>@cart.TaxAmount.ToString("C")</span>
                        </div>
                        <div class="flex justify-between text-xl font-bold text-white pt-2 border-t border-gray-700">
                            <span>Total</span>
                            <span>@cart.GrandTotal.ToString("C")</span>
                        </div>
                    </div>

                    <div class="px-6 pb-6">
                        <button class="w-full py-4 bg-gradient-to-r from-green-500 to-emerald-500 hover:from-green-400 hover:to-emerald-400 text-white text-lg font-bold rounded-2xl transition-all active:scale-[0.98] shadow-lg shadow-green-500/30"
                                @onclick="OpenCheckout">
                            Checkout · @cart.GrandTotal.ToString("C")
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modals -->
<PosComboOfferModal @ref="comboModal" Combo="pendingCombo" TriggerItem="pendingTriggerItem" OnResult="HandleComboResult" />
<PosItemDetailModal @ref="itemDetailModal" Item="selectedCartItemProxy" OnQuantityChanged="HandleQuantityChanged" OnRemove="HandleItemRemove" />
<PosCheckoutModal @ref="checkoutModal" Order="checkoutOrder" OnPaymentComplete="HandlePaymentComplete" OnCancel="HandleCheckoutCancel" />
<PosReceiptModal @ref="receiptModal" Order="checkoutOrder" Payment="completedPayment" OnNewOrder="StartNewOrder" />

@code {
    [Parameter] public Guid MenuId { get; set; }

    // Data loaded once from DB (read-only)
    private Menu? menu;
    private List<Category> categories = new();
    private List<MenuItem> allMenuItems = new();
    private List<MenuCombo> allCombos = new();
    private decimal defaultTaxRate;
    private Guid menuOwnerId;

    // Server-side cart via PosSessionService (only sessionId on client)
    private Guid sessionId;
    private PosCart cart = new();
    private Guid? selectedCategoryId;
    private bool showMobileCart;
    private bool initialized;

    // Modal state
    private PosComboOfferModal comboModal = default!;
    private PosItemDetailModal itemDetailModal = default!;
    private PosCheckoutModal checkoutModal = default!;
    private PosReceiptModal receiptModal = default!;
    private MenuCombo? pendingCombo;
    private MenuItem? pendingTriggerItem;
    private OrderItem? selectedCartItemProxy;
    private Order? checkoutOrder;
    private PosPayment? completedPayment;

    private IEnumerable<MenuItem> filteredItems =>
        selectedCategoryId == null ? allMenuItems : allMenuItems.Where(i => i.CategoryId == selectedCategoryId);

    protected override async Task OnInitializedAsync()
    {
        menu = await Context.Menus.IgnoreQueryFilters().FirstOrDefaultAsync(m => m.Id == MenuId);
        if (menu == null) return;

        menuOwnerId = menu.ApplicationUserId;

        categories = await Context.Categories.IgnoreQueryFilters()
            .Where(c => c.MenuId == MenuId).OrderBy(c => c.Name).ToListAsync();

        allMenuItems = await Context.MenuItems.IgnoreQueryFilters()
            .Include(mi => mi.TaxRate)
            .Where(mi => Context.Categories.IgnoreQueryFilters().Any(c => c.MenuId == MenuId && c.Id == mi.CategoryId))
            .OrderBy(mi => mi.Name).ToListAsync();

        allCombos = await Context.MenuCombos.IgnoreQueryFilters()
            .Include(c => c.Items).ThenInclude(i => i.MenuItem)
            .Where(c => c.MenuId == MenuId).ToListAsync();

        var defaultTax = await Context.TaxRates.IgnoreQueryFilters()
            .FirstOrDefaultAsync(t => t.ApplicationUserId == menuOwnerId && t.IsDefault);
        defaultTaxRate = defaultTax?.Rate ?? 0m;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Restore or create session
            var storedId = await JS.InvokeAsync<string?>("sessionStorage.getItem", $"pos_sid_{MenuId}");
            if (!string.IsNullOrEmpty(storedId) && Guid.TryParse(storedId, out var parsed))
            {
                sessionId = parsed;
            }
            else
            {
                sessionId = SessionService.CreateSessionId();
                await JS.InvokeVoidAsync("sessionStorage.setItem", $"pos_sid_{MenuId}", sessionId.ToString());
            }
            cart = SessionService.GetCart(sessionId);
            initialized = true;
            StateHasChanged();
        }
    }

    // ════════════════ CART OPERATIONS (server-side via PosSessionService) ════════════════

    private void SaveCart()
    {
        SessionService.SaveCart(sessionId, cart);
    }

    private void HandleItemTap(MenuItem item)
    {
        var combo = allCombos.FirstOrDefault(c => c.TriggerMenuItemId == item.Id);
        if (combo != null)
        {
            pendingCombo = combo;
            pendingTriggerItem = item;
            comboModal.Show();
            return;
        }

        var taxRate = ResolveTaxRate(item);
        cart.IncrementOrAdd(item.Id, item.Name, item.Price, taxRate);
        SaveCart();
    }

    private void HandleComboResult(bool acceptCombo)
    {
        if (pendingTriggerItem == null) return;

        if (acceptCombo && pendingCombo != null)
        {
            var triggerTaxRate = ResolveTaxRate(pendingTriggerItem);
            cart.AddItem(pendingTriggerItem.Id, pendingTriggerItem.Name, pendingCombo.ComboPrice,
                triggerTaxRate, pendingCombo.Id, isComboTrigger: true);

            foreach (var comboItem in pendingCombo.Items)
            {
                var mi = allMenuItems.FirstOrDefault(m => m.Id == comboItem.MenuItemId);
                if (mi != null)
                {
                    cart.AddItem(mi.Id, mi.Name, 0, ResolveTaxRate(mi), pendingCombo.Id, isComboTrigger: false);
                }
            }
        }
        else
        {
            cart.IncrementOrAdd(pendingTriggerItem.Id, pendingTriggerItem.Name,
                pendingTriggerItem.Price, ResolveTaxRate(pendingTriggerItem));
        }

        pendingCombo = null;
        pendingTriggerItem = null;
        SaveCart();
    }

    private decimal ResolveTaxRate(MenuItem item) => item.TaxRate?.Rate ?? defaultTaxRate;

    private void OpenItemDetail(int index)
    {
        if (index < 0 || index >= cart.Items.Count) return;
        var ci = cart.Items[index];
        selectedCartItemProxy = new OrderItem
        {
            Id = Guid.NewGuid(), ItemName = ci.Name, UnitPrice = ci.UnitPrice,
            Quantity = ci.Quantity, IsComboItem = false, LineTotal = ci.LineTotal
        };
        _editingCartIndex = index;
        _editingIsCombo = false;
        itemDetailModal.Show();
    }

    private void OpenComboDetail(int triggerIndex)
    {
        if (triggerIndex < 0 || triggerIndex >= cart.Items.Count) return;
        var ci = cart.Items[triggerIndex];
        selectedCartItemProxy = new OrderItem
        {
            Id = Guid.NewGuid(), ItemName = ci.Name + " (Combo)", UnitPrice = ci.UnitPrice,
            Quantity = ci.Quantity, IsComboItem = false, LineTotal = ci.LineTotal
        };
        _editingCartIndex = triggerIndex;
        _editingIsCombo = true;
        itemDetailModal.Show();
    }

    private int _editingCartIndex = -1;
    private bool _editingIsCombo;

    private void HandleQuantityChanged((Guid ItemId, int Quantity) result)
    {
        if (_editingCartIndex < 0 || _editingCartIndex >= cart.Items.Count) return;

        if (_editingIsCombo)
        {
            var comboId = cart.Items[_editingCartIndex].ComboId;
            if (comboId.HasValue)
                cart.UpdateComboQuantity(comboId.Value, result.Quantity);
        }
        else
        {
            cart.Items[_editingCartIndex].Quantity = result.Quantity;
            cart.Items[_editingCartIndex].Recalculate();
            cart.Recalculate();
        }

        SaveCart();
        _editingIsCombo = false;
    }

    private void HandleItemRemove(Guid itemId)
    {
        if (_editingCartIndex < 0 || _editingCartIndex >= cart.Items.Count) return;

        if (_editingIsCombo)
        {
            var comboId = cart.Items[_editingCartIndex].ComboId;
            if (comboId.HasValue)
                cart.RemoveCombo(comboId.Value);
        }
        else
        {
            cart.Items.RemoveAt(_editingCartIndex);
            cart.Recalculate();
        }

        SaveCart();
        _editingIsCombo = false;
    }

    private void ClearCart()
    {
        SessionService.ClearCart(sessionId);
        cart = SessionService.GetCart(sessionId);
    }

    private bool HasCombo(Guid menuItemId) => allCombos.Any(c => c.TriggerMenuItemId == menuItemId);

    // ════════════════ CHECKOUT ════════════════

    private async Task OpenCheckout()
    {
        showMobileCart = false;

        var items = cart.Items.Select(ci => new CreateOrderItemDto
        {
            MenuItemId = ci.MenuItemId,
            Quantity = ci.Quantity,
            MenuComboId = ci.ComboId
        }).ToList();

        checkoutOrder = await OrderService.CreatePosOrderAsync(MenuId, menuOwnerId, items);
        checkoutModal.Show();
    }

    private async Task HandlePaymentComplete(PosPayment payment)
    {
        completedPayment = payment;
        SessionService.ClearCart(sessionId);
        cart = SessionService.GetCart(sessionId);
        receiptModal.Show();
    }

    private void HandleCheckoutCancel()
    {
        if (checkoutOrder != null)
        {
            _ = OrderService.CancelOrderAsync(checkoutOrder.Id, "Payment cancelled");
            checkoutOrder = null;
        }
    }

    private async Task StartNewOrder()
    {
        // New session for next customer
        sessionId = SessionService.CreateSessionId();
        await JS.InvokeVoidAsync("sessionStorage.setItem", $"pos_sid_{MenuId}", sessionId.ToString());
        cart = SessionService.GetCart(sessionId);
        checkoutOrder = null;
        completedPayment = null;
    }
}
