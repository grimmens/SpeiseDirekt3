@page "/pos/login"
@using Microsoft.AspNetCore.Authorization
@using SpeiseDirekt.ServiceInterface
@layout PosLayout
@inject IPosCustomerService CustomerService
@inject IJSRuntime JS
@inject NavigationManager NavManager
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<div class="min-h-[calc(100vh-3.5rem)] flex flex-col items-center bg-gray-50">
    <!-- Orange header area -->
    <div class="w-full py-8 px-4 text-center" style="background: linear-gradient(135deg, #FF8000, #FF9A33);">
        <svg class="w-12 h-12 mx-auto mb-3" viewBox="0 0 24 24" fill="none">
            <rect width="24" height="24" rx="6" fill="white"/>
            <path d="M7 8h10M7 12h7M7 16h10" stroke="#FF8000" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <h1 class="text-2xl font-bold text-white">Anmelden oder registrieren</h1>
        <p class="text-white/80 text-sm mt-1">Bestelle schneller mit deinem Konto</p>
    </div>

    <!-- Card -->
    <div class="w-full max-w-md mx-auto -mt-4 px-4 pb-20 lg:pb-8">
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
            <!-- Tab toggle -->
            <div class="flex border-b border-gray-200">
                <button @onclick="() => activeTab = Tab.Login"
                        class="flex-1 py-3.5 text-sm font-semibold text-center transition-colors relative @(activeTab == Tab.Login ? "text-[#FF8000]" : "text-gray-500 hover:text-gray-700")">
                    Anmelden
                    @if (activeTab == Tab.Login)
                    {
                        <span class="absolute bottom-0 left-0 right-0 h-0.5" style="background-color: #FF8000;"></span>
                    }
                </button>
                <button @onclick="() => activeTab = Tab.Signup"
                        class="flex-1 py-3.5 text-sm font-semibold text-center transition-colors relative @(activeTab == Tab.Signup ? "text-[#FF8000]" : "text-gray-500 hover:text-gray-700")">
                    Registrieren
                    @if (activeTab == Tab.Signup)
                    {
                        <span class="absolute bottom-0 left-0 right-0 h-0.5" style="background-color: #FF8000;"></span>
                    }
                </button>
            </div>

            <div class="p-6">
                @if (activeTab == Tab.Login)
                {
                    <!-- Login form -->
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">E-Mail</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                    <polyline points="22,6 12,13 2,6"/>
                                </svg>
                                <input type="email" @bind="loginEmail" placeholder="deine@email.de"
                                       class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow" />
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Passwort</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0110 0v4"/>
                                </svg>
                                <input type="password" @bind="loginPassword" placeholder="Passwort eingeben"
                                       class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <p class="text-red-500 text-sm">@errorMessage</p>
                        }

                        <button @onclick="HandleLogin" disabled="@isSubmitting"
                                class="w-full py-3 rounded-full text-white font-semibold text-sm transition-all hover:opacity-90 disabled:opacity-50"
                                style="background-color: #FF8000;">
                            @if (isSubmitting)
                            {
                                <span>Wird geladen...</span>
                            }
                            else
                            {
                                <span>Anmelden</span>
                            }
                        </button>
                    </div>
                }
                else
                {
                    <!-- Sign up form -->
                    <div class="space-y-4">
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Vorname</label>
                                <input type="text" @bind="signupFirstName" placeholder="Max"
                                       class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Nachname</label>
                                <input type="text" @bind="signupLastName" placeholder="Mustermann"
                                       class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow" />
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">E-Mail</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                    <polyline points="22,6 12,13 2,6"/>
                                </svg>
                                <input type="email" @bind="signupEmail" placeholder="deine@email.de"
                                       class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow" />
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Telefonnummer</label>
                            <div class="relative">
                                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                                </svg>
                                <input type="tel" @bind="signupPhone" placeholder="+49 123 456789"
                                       class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition-shadow" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <p class="text-red-500 text-sm">@errorMessage</p>
                        }

                        <button @onclick="HandleSignup" disabled="@isSubmitting"
                                class="w-full py-3 rounded-full text-white font-semibold text-sm transition-all hover:opacity-90 disabled:opacity-50"
                                style="background-color: #FF8000;">
                            @if (isSubmitting)
                            {
                                <span>Wird geladen...</span>
                            }
                            else
                            {
                                <span>Konto erstellen</span>
                            }
                        </button>
                    </div>
                }

                <!-- Divider -->
                <div class="flex items-center gap-3 my-5">
                    <div class="flex-1 h-px bg-gray-200"></div>
                    <span class="text-xs text-gray-400 font-medium">ODER</span>
                    <div class="flex-1 h-px bg-gray-200"></div>
                </div>

                <!-- Continue as guest -->
                <button @onclick="HandleGuestContinue"
                        class="w-full py-3 rounded-full border-2 font-semibold text-sm transition-all hover:bg-orange-50"
                        style="border-color: #FF8000; color: #FF8000;">
                    Als Gast fortfahren
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private enum Tab { Login, Signup }
    private Tab activeTab = Tab.Login;

    // Login fields
    private string loginEmail = "";
    private string loginPassword = "";

    // Signup fields
    private string signupFirstName = "";
    private string signupLastName = "";
    private string signupEmail = "";
    private string signupPhone = "";

    private string? errorMessage;
    private bool isSubmitting;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string GetReturnUrl() => string.IsNullOrWhiteSpace(ReturnUrl) ? "/pos" : ReturnUrl;

    private async Task HandleLogin()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(loginEmail))
        {
            errorMessage = "Bitte gib deine E-Mail-Adresse ein.";
            return;
        }

        isSubmitting = true;
        try
        {
            var sessionId = Guid.NewGuid().ToString();
            var session = new PosCustomerSession
            {
                Email = loginEmail.Trim(),
                IsGuest = false
            };

            CustomerService.SaveSession(sessionId, session);
            await JS.InvokeVoidAsync("sessionStorage.setItem", "pos_customer_sid", sessionId);
            NavManager.NavigateTo(GetReturnUrl());
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task HandleSignup()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(signupEmail))
        {
            errorMessage = "Bitte gib deine E-Mail-Adresse ein.";
            return;
        }
        if (string.IsNullOrWhiteSpace(signupFirstName))
        {
            errorMessage = "Bitte gib deinen Vornamen ein.";
            return;
        }

        isSubmitting = true;
        try
        {
            var sessionId = Guid.NewGuid().ToString();
            var session = new PosCustomerSession
            {
                Email = signupEmail.Trim(),
                FirstName = signupFirstName.Trim(),
                LastName = signupLastName.Trim(),
                Phone = signupPhone.Trim(),
                IsGuest = false
            };

            CustomerService.SaveSession(sessionId, session);
            await JS.InvokeVoidAsync("sessionStorage.setItem", "pos_customer_sid", sessionId);
            NavManager.NavigateTo(GetReturnUrl());
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task HandleGuestContinue()
    {
        var sessionId = Guid.NewGuid().ToString();
        var session = new PosCustomerSession { IsGuest = true };

        CustomerService.SaveSession(sessionId, session);
        await JS.InvokeVoidAsync("sessionStorage.setItem", "pos_customer_sid", sessionId);
        NavManager.NavigateTo(GetReturnUrl());
    }
}
