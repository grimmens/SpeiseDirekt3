@page "/pos/{MenuId:guid}/checkout"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using SpeiseDirekt.Model
@using SpeiseDirekt.ServiceInterface
@layout PosLayout
@inject ApplicationDbContext Context
@inject IOrderService OrderService
@inject IPosSessionService SessionService
@inject IPosPaymentService PaymentService
@inject IPosLocationService LocationService
@inject IPosCustomerService CustomerService
@inject IAddressService AddressService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IJSRuntime JS
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Checkout - Speise-Direkt</PageTitle>

<div class="flex flex-col min-h-screen bg-gray-50">

    <!-- Sticky Header -->
    <div class="sticky top-0 z-10 bg-white shadow-sm flex items-center px-4 h-14">
        <button class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors" @onclick="GoBack" disabled="@isProcessing">
            <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </button>
        <h1 class="ml-3 text-lg font-bold text-gray-900">Checkout</h1>
    </div>

    @if (!initialized)
    {
        <div class="flex-1 flex items-center justify-center">
            <div class="animate-spin rounded-full h-8 w-8 border-2 border-gray-300 border-t-[#FF8000]"></div>
        </div>
    }
    else if (order == null)
    {
        <div class="flex-1 flex flex-col items-center justify-center px-8 text-center">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
            </div>
            <h3 class="text-base font-bold text-gray-800 mb-1">Dein Warenkorb ist leer</h3>
            <a href="/pos/@MenuId" class="mt-4 px-6 py-2.5 rounded-full text-white font-semibold text-sm" style="background-color: #FF8000;">Zurück zur Speisekarte</a>
        </div>
    }
    else
    {
        <!-- Scrollable content -->
        <div class="flex-1 overflow-y-auto pb-28">
            <div class="max-w-2xl mx-auto px-4 pt-4 space-y-4">

                <!-- Delivery Address Section -->
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-orange-50 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#FF8000]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h2 class="text-sm font-semibold text-gray-900">Lieferadresse</h2>
                            @if (!string.IsNullOrEmpty(deliveryStreet))
                            {
                                <p class="text-sm text-gray-500 mt-0.5">@($"{deliveryStreet} {deliveryHouseNumber}".Trim()), @deliveryPostalCode @deliveryCity</p>
                            }
                            else
                            {
                                <p class="text-sm text-gray-400 mt-0.5">Keine Adresse angegeben</p>
                                @if (validationErrors.ContainsKey("address"))
                                {
                                    <p class="text-xs text-red-500 mt-0.5">@validationErrors["address"]</p>
                                }
                            }
                        </div>
                        <button class="text-sm font-medium text-[#FF8000] hover:underline" @onclick="() => showAddressSearch = !showAddressSearch">
                            @(showAddressSearch ? "Schließen" : (string.IsNullOrEmpty(deliveryStreet) ? "Hinzufügen" : "Ändern"))
                        </button>
                    </div>

                    @if (isRegisteredUser && savedAddresses.Any())
                    {
                        <div class="space-y-2 mb-3">
                            @foreach (var saved in savedAddresses)
                            {
                                var isSelected = selectedAddressId == saved.Id;
                                <button class="w-full text-left p-3 rounded-lg border-2 transition-all @(isSelected ? "border-[#FF8000] bg-orange-50" : "border-gray-200 hover:border-gray-300")"
                                        @onclick="() => SelectSavedAddress(saved.Id)">
                                    <div class="flex items-center gap-3">
                                        <div class="w-4 h-4 rounded-full border-2 flex items-center justify-center flex-shrink-0 @(isSelected ? "border-[#FF8000]" : "border-gray-300")">
                                            @if (isSelected)
                                            {
                                                <div class="w-2 h-2 rounded-full bg-[#FF8000]"></div>
                                            }
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            @if (!string.IsNullOrWhiteSpace(saved.Label))
                                            {
                                                <div class="text-xs font-semibold text-gray-700">@saved.Label</div>
                                            }
                                            <div class="text-sm text-gray-900 truncate">@saved.Street @saved.HouseNumber</div>
                                            <div class="text-xs text-gray-500">@saved.PostalCode @saved.City</div>
                                        </div>
                                    </div>
                                </button>
                            }
                        </div>
                    }

                    @if (showAddressSearch)
                    {
                        <div class="relative">
                            <input type="text" placeholder="Adresse suchen..."
                                   class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF8000]/30 focus:border-[#FF8000]"
                                   @bind="addressQuery" @bind:event="oninput" @onkeyup="OnAddressInput" />
                            @if (addressResults.Any())
                            {
                                <div class="absolute left-0 right-0 top-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg z-10 max-h-48 overflow-y-auto">
                                    @foreach (var result in addressResults)
                                    {
                                        <button class="w-full text-left px-4 py-3 text-sm hover:bg-gray-50 border-b border-gray-100 last:border-0"
                                                @onclick="() => SelectLocationResult(result)">
                                            <span class="font-medium text-gray-900">@result.Street @result.HouseNumber</span>
                                            <span class="text-gray-400 ml-1">@result.PostalCode @result.City</span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Customer Details Section -->
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-orange-50 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#FF8000]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900">Kontaktdaten</h2>
                    </div>

                    <div class="space-y-3">
                        <div>
                            <label class="text-xs text-gray-500 font-medium mb-1 block">Name *</label>
                            <div class="relative">
                                <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                <input type="text" placeholder="Dein Name" @bind="customerName"
                                       class="w-full border rounded-lg pl-10 pr-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF8000]/30 focus:border-[#FF8000] @(validationErrors.ContainsKey("name") ? "border-red-300" : "border-gray-200")" />
                            </div>
                            @if (validationErrors.ContainsKey("name"))
                            {
                                <p class="text-xs text-red-500 mt-1">@validationErrors["name"]</p>
                            }
                        </div>
                        <div>
                            <label class="text-xs text-gray-500 font-medium mb-1 block">E-Mail *</label>
                            <div class="relative">
                                <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                                <input type="email" placeholder="email@beispiel.de" @bind="customerEmail"
                                       class="w-full border rounded-lg pl-10 pr-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF8000]/30 focus:border-[#FF8000] @(validationErrors.ContainsKey("email") ? "border-red-300" : "border-gray-200")" />
                            </div>
                            @if (validationErrors.ContainsKey("email"))
                            {
                                <p class="text-xs text-red-500 mt-1">@validationErrors["email"]</p>
                            }
                        </div>
                        <div>
                            <label class="text-xs text-gray-500 font-medium mb-1 block">Telefon</label>
                            <div class="relative">
                                <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                </svg>
                                <input type="tel" placeholder="+49 123 456789" @bind="customerPhone"
                                       class="w-full border border-gray-200 rounded-lg pl-10 pr-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF8000]/30 focus:border-[#FF8000]" />
                            </div>
                        </div>
                    </div>

                    @if (!isRegisteredUser)
                    {
                        <div class="mt-3 pt-3 border-t border-gray-100">
                            <a href="/pos/account/login?returnUrl=@(Uri.EscapeDataString(NavManager.Uri))" class="text-sm font-medium text-[#FF8000] hover:underline">
                                Anmelden für schnellere Bestellung →
                            </a>
                        </div>
                    }
                </div>

                <!-- Payment Method Section -->
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-orange-50 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#FF8000]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900">Zahlungsart</h2>
                    </div>

                    <div class="space-y-3">
                        <button class="w-full flex items-center gap-4 p-4 rounded-xl border-2 transition-all @(selectedMethod == PosPaymentMethod.Card ? "border-[#FF8000] bg-orange-50" : "border-gray-200 hover:border-gray-300")"
                                @onclick="() => selectedMethod = PosPaymentMethod.Card">
                            <div class="w-5 h-5 rounded-full border-2 flex items-center justify-center @(selectedMethod == PosPaymentMethod.Card ? "border-[#FF8000]" : "border-gray-300")">
                                @if (selectedMethod == PosPaymentMethod.Card)
                                {
                                    <div class="w-3 h-3 rounded-full bg-[#FF8000]"></div>
                                }
                            </div>
                            <svg class="w-6 h-6 @(selectedMethod == PosPaymentMethod.Card ? "text-[#FF8000]" : "text-gray-400")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                            </svg>
                            <div class="flex-1 text-left">
                                <span class="text-sm font-semibold @(selectedMethod == PosPaymentMethod.Card ? "text-gray-900" : "text-gray-600")">Kredit-/Debitkarte</span>
                                <div class="flex gap-1.5 mt-1">
                                    <span class="text-[10px] px-1.5 py-0.5 bg-blue-100 text-blue-700 rounded font-bold">VISA</span>
                                    <span class="text-[10px] px-1.5 py-0.5 bg-red-100 text-red-600 rounded font-bold">MC</span>
                                </div>
                            </div>
                        </button>

                        <button class="w-full flex items-center gap-4 p-4 rounded-xl border-2 transition-all @(selectedMethod == PosPaymentMethod.Cash ? "border-[#FF8000] bg-orange-50" : "border-gray-200 hover:border-gray-300")"
                                @onclick="() => selectedMethod = PosPaymentMethod.Cash">
                            <div class="w-5 h-5 rounded-full border-2 flex items-center justify-center @(selectedMethod == PosPaymentMethod.Cash ? "border-[#FF8000]" : "border-gray-300")">
                                @if (selectedMethod == PosPaymentMethod.Cash)
                                {
                                    <div class="w-3 h-3 rounded-full bg-[#FF8000]"></div>
                                }
                            </div>
                            <svg class="w-6 h-6 @(selectedMethod == PosPaymentMethod.Cash ? "text-[#FF8000]" : "text-gray-400")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                            <div class="flex-1 text-left">
                                <span class="text-sm font-semibold @(selectedMethod == PosPaymentMethod.Cash ? "text-gray-900" : "text-gray-600")">Barzahlung</span>
                                <p class="text-xs text-gray-400 mt-0.5">Bei Lieferung bezahlen</p>
                            </div>
                        </button>
                    </div>
                </div>

                <!-- Order Summary Section -->
                <div class="bg-white rounded-xl shadow-sm p-6">
                    <button class="w-full flex items-center justify-between" @onclick="() => showOrderDetails = !showOrderDetails">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-orange-50 rounded-full flex items-center justify-center">
                                <svg class="w-5 h-5 text-[#FF8000]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                </svg>
                            </div>
                            <h2 class="text-sm font-semibold text-gray-900">Bestellübersicht (@order.Items.Sum(i => i.Quantity) Artikel)</h2>
                        </div>
                        <svg class="w-5 h-5 text-gray-400 transition-transform @(showOrderDetails ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    @if (showOrderDetails)
                    {
                        <div class="mt-4 pt-4 border-t border-gray-100 space-y-2">
                            @foreach (var item in order.Items)
                            {
                                <div class="flex justify-between items-center py-1.5">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm text-gray-500">@item.Quantity ×</span>
                                        <span class="text-sm text-gray-900">@item.ItemName</span>
                                        @if (item.IsComboItem)
                                        {
                                            <span class="text-[10px] px-1.5 py-0.5 bg-orange-100 text-orange-600 rounded-full font-medium">COMBO</span>
                                        }
                                    </div>
                                    <span class="text-sm text-gray-700 font-medium">@item.LineTotal.ToString("C")</span>
                                </div>
                            }
                        </div>
                    }

                    <div class="mt-4 pt-4 border-t border-gray-100 space-y-2">
                        <div class="flex justify-between text-sm text-gray-500">
                            <span>Zwischensumme</span>
                            <span>@order.SubTotal.ToString("C")</span>
                        </div>
                        <div class="flex justify-between text-sm text-gray-500">
                            <span>Liefergebühr</span>
                            <span class="text-green-600 font-medium">€0,00</span>
                        </div>
                        <div class="flex justify-between text-sm text-gray-500">
                            <span>MwSt.</span>
                            <span>@order.TaxAmount.ToString("C")</span>
                        </div>
                        @if (order.DiscountAmount > 0)
                        {
                            <div class="flex justify-between text-sm text-green-600 font-medium">
                                <span>Rabatt</span>
                                <span>-@order.DiscountAmount.ToString("C")</span>
                            </div>
                        }
                        <div class="flex justify-between text-lg font-bold text-gray-900 pt-3 border-t border-gray-200">
                            <span>Gesamt</span>
                            <span>@order.GrandTotal.ToString("C")</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- Error message -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="max-w-2xl mx-auto mx-4 mb-2 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-600 text-center">
                @errorMessage
            </div>
        }

        <!-- Sticky Bottom Bar -->
        <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-20">
            <div class="max-w-2xl mx-auto px-2 py-4">
                <button class="w-full py-2 bg-[#FF8000] hover:bg-[#E67300] text-white text-lg font-bold rounded-full transition-all active:scale-[0.98] shadow-lg disabled:opacity-50 disabled:cursor-not-allowed"
                        @onclick="ProcessPayment" disabled="@(!CanPlaceOrder)">
                    @if (isProcessing)
                    {
                        <div class="flex items-center justify-center gap-2">
                            <div class="animate-spin rounded-full h-5 w-5 border-2 border-white/30 border-t-white"></div>
                            <span>Wird verarbeitet...</span>
                        </div>
                    }
                    else
                    {
                        <span>Bestellung aufgeben — @order.GrandTotal.ToString("C")</span>
                    }
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid MenuId { get; set; }

    private bool initialized;
    private Order? order;
    private Guid cartSessionId;

    private bool isProcessing;
    private string? errorMessage;
    private PosPaymentMethod selectedMethod = PosPaymentMethod.Cash;

    // Session
    private string? customerSessionId;
    private bool isRegisteredUser;
    private List<Address> savedAddresses = new();
    private Guid? selectedAddressId;

    // Address
    private string? deliveryStreet;
    private string? deliveryHouseNumber;
    private string? deliveryCity;
    private string? deliveryPostalCode;
    private bool showAddressSearch;
    private string addressQuery = "";
    private List<LocationResult> addressResults = new();
    private System.Timers.Timer? addressDebounce;

    // Customer
    private string? customerName;
    private string? customerEmail;
    private string? customerPhone;

    // Order summary
    private bool showOrderDetails = true;

    // Validation
    private Dictionary<string, string> validationErrors = new();

    private bool CanPlaceOrder => !isProcessing && order != null && validationErrors.Count == 0
        && !string.IsNullOrWhiteSpace(customerEmail)
        && !string.IsNullOrWhiteSpace(deliveryStreet)
        && !string.IsNullOrWhiteSpace(customerName);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Load cart session
        var storedId = await JS.InvokeAsync<string?>("sessionStorage.getItem", $"pos_sid_{MenuId}");
        if (string.IsNullOrEmpty(storedId) || !Guid.TryParse(storedId, out var parsed))
        {
            initialized = true;
            StateHasChanged();
            return;
        }

        cartSessionId = parsed;
        var cart = SessionService.GetCart(cartSessionId);
        if (!cart.Items.Any())
        {
            initialized = true;
            StateHasChanged();
            return;
        }

        // Create draft order from cart
        var menu = await Context.Menus.IgnoreQueryFilters().FirstOrDefaultAsync(m => m.Id == MenuId);
        if (menu == null)
        {
            initialized = true;
            StateHasChanged();
            return;
        }

        var items = cart.Items.Select(ci => new CreateOrderItemDto
        {
            MenuItemId = ci.MenuItemId,
            Quantity = ci.Quantity,
            MenuComboId = ci.ComboId
        }).ToList();

        order = await OrderService.CreatePosOrderAsync(MenuId, menu.ApplicationUserId, items);

        // Load customer session
        await LoadCustomerSessionAsync();

        initialized = true;
        StateHasChanged();
    }

    private async Task LoadCustomerSessionAsync()
    {
        customerSessionId = await JS.InvokeAsync<string?>("sessionStorage.getItem", "pos_customer_sid");
        if (string.IsNullOrEmpty(customerSessionId))
        {
            customerSessionId = Guid.NewGuid().ToString();
            await JS.InvokeVoidAsync("sessionStorage.setItem", "pos_customer_sid", customerSessionId);
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.Identity?.IsAuthenticated == true
            ? authState.User.FindFirstValue(ClaimTypes.NameIdentifier)
            : null;

        var session = await CustomerService.GetOrCreateSessionAsync(customerSessionId, userId);

        isRegisteredUser = session is RegisteredUserPosSession;
        customerEmail = session.Email;
        customerPhone = session.Phone;
        customerName = session.FullName;

        if (session.DeliveryAddress != null)
        {
            deliveryStreet = session.DeliveryAddress.Street;
            deliveryHouseNumber = session.DeliveryAddress.HouseNumber;
            deliveryCity = session.DeliveryAddress.City;
            deliveryPostalCode = session.DeliveryAddress.PostalCode;
        }

        if (session is RegisteredUserPosSession registered)
        {
            savedAddresses = await AddressService.GetForUserAsync(registered.ApplicationUserId);
            selectedAddressId = registered.SelectedAddressId;
        }
    }

    private async Task SelectSavedAddress(Guid addressId)
    {
        if (customerSessionId == null) return;
        var session = await CustomerService.SelectAddressAsync(customerSessionId, addressId);
        if (session == null) return;

        selectedAddressId = session.SelectedAddressId;
        if (session.DeliveryAddress != null)
        {
            deliveryStreet = session.DeliveryAddress.Street;
            deliveryHouseNumber = session.DeliveryAddress.HouseNumber;
            deliveryCity = session.DeliveryAddress.City;
            deliveryPostalCode = session.DeliveryAddress.PostalCode;
        }
        showAddressSearch = false;
    }

    private void SelectLocationResult(LocationResult result)
    {
        deliveryStreet = result.Street;
        deliveryHouseNumber = result.HouseNumber;
        deliveryCity = result.City;
        deliveryPostalCode = result.PostalCode;
        selectedAddressId = null;
        addressResults.Clear();
        showAddressSearch = false;
        addressQuery = "";
    }

    private void OnAddressInput()
    {
        addressDebounce?.Stop();
        addressDebounce?.Dispose();
        addressDebounce = new System.Timers.Timer(500);
        addressDebounce.Elapsed += async (_, _) =>
        {
            addressDebounce?.Stop();
            if (!string.IsNullOrWhiteSpace(addressQuery) && addressQuery.Length >= 3)
            {
                var results = await LocationService.SearchAsync(addressQuery, "de");
                await InvokeAsync(() =>
                {
                    addressResults = results;
                    StateHasChanged();
                });
            }
        };
        addressDebounce.AutoReset = false;
        addressDebounce.Start();
    }

    private bool Validate()
    {
        validationErrors.Clear();

        if (string.IsNullOrWhiteSpace(customerName))
            validationErrors["name"] = "Bitte gib deinen Namen ein.";

        if (string.IsNullOrWhiteSpace(customerEmail))
            validationErrors["email"] = "Bitte gib deine E-Mail-Adresse ein.";
        else if (!System.Text.RegularExpressions.Regex.IsMatch(customerEmail.Trim(), @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            validationErrors["email"] = "Bitte gib eine gültige E-Mail-Adresse ein.";

        if (string.IsNullOrWhiteSpace(deliveryStreet) || string.IsNullOrWhiteSpace(deliveryCity))
            validationErrors["address"] = "Bitte gib eine Lieferadresse an.";

        return validationErrors.Count == 0;
    }

    private async Task ProcessPayment()
    {
        if (order == null) return;
        errorMessage = null;

        if (!Validate())
        {
            StateHasChanged();
            return;
        }

        isProcessing = true;

        try
        {
            if (customerSessionId != null)
            {
                CustomerService.UpdateContact(customerSessionId, customerEmail, customerName, null, customerPhone);
                if (selectedAddressId == null && !string.IsNullOrWhiteSpace(deliveryStreet))
                {
                    CustomerService.UpdateDeliveryAddress(customerSessionId, new PosSessionAddress
                    {
                        Street = deliveryStreet,
                        HouseNumber = deliveryHouseNumber,
                        City = deliveryCity,
                        PostalCode = deliveryPostalCode,
                    });
                }
            }

            var orderStreetLine = string.IsNullOrWhiteSpace(deliveryHouseNumber)
                ? deliveryStreet
                : $"{deliveryStreet} {deliveryHouseNumber}".Trim();
            await OrderService.UpdateCustomerDetailsAsync(
                order.Id, customerName, customerEmail, customerPhone,
                orderStreetLine, deliveryCity, deliveryPostalCode);

            // Clear the cart now that the order is confirmed
            SessionService.ClearCart(cartSessionId);

            if (selectedMethod == PosPaymentMethod.Cash)
            {
                await PaymentService.CreateCashPaymentAsync(order.Id);
                NavManager.NavigateTo($"/pos/{MenuId}/receipt/{order.Id}");
            }
            else
            {
                var baseUrl = NavManager.BaseUri.TrimEnd('/');
                var successUrl = $"{baseUrl}/pos/{MenuId}/receipt/{order.Id}";
                var cancelUrl = $"{baseUrl}/pos/{MenuId}/checkout";
                var (_, checkoutUrl) = await PaymentService.CreateStripeCheckoutAsync(order.Id, successUrl, cancelUrl);
                NavManager.NavigateTo(checkoutUrl, forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task GoBack()
    {
        if (order != null)
        {
            _ = OrderService.CancelOrderAsync(order.Id, "Checkout abgebrochen");
        }
        NavManager.NavigateTo($"/pos/{MenuId}");
    }
}
