@page "/pos"
@page "/pos/kiosk"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using SpeiseDirekt.Model
@layout PosLayout
@inject ApplicationDbContext Context
@inject NavigationManager NavManager
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Order Here</PageTitle>

<div class="flex-1 flex flex-col items-center justify-center px-6 py-12">
    <!-- Logo / Welcome -->
    <div class="text-center mb-12">
        <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-amber-400 to-orange-500 rounded-2xl flex items-center justify-center shadow-xl shadow-amber-500/20">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-white font-display mb-3">Welcome</h1>
        <p class="text-xl text-gray-400">Tap a menu to start your order</p>
    </div>

    <!-- Menu Cards -->
    @if (menus != null && menus.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl w-full">
            @foreach (var menu in menus)
            {
                <button class="group relative overflow-hidden bg-gradient-to-br from-gray-700 to-gray-800 rounded-2xl p-8 text-left hover:from-amber-600 hover:to-orange-600 transition-all duration-300 shadow-lg hover:shadow-2xl hover:shadow-amber-500/20 hover:scale-[1.02] active:scale-[0.98]"
                        @onclick="() => GoToMenu(menu.Id)">
                    <div class="relative z-10">
                        <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-white">@menu.Name</h2>
                        <p class="text-gray-400 group-hover:text-amber-100 text-sm">@menu.Description</p>
                        <div class="mt-6 flex items-center text-amber-400 group-hover:text-white font-semibold">
                            <span>Start Order</span>
                            <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                            </svg>
                        </div>
                    </div>
                </button>
            }
        </div>
    }
    else if (menus != null)
    {
        <div class="text-center text-gray-500">
            <p class="text-lg">No menus available at this time.</p>
        </div>
    }
    else
    {
        <div class="flex items-center gap-3 text-gray-400">
            <div class="animate-spin rounded-full h-6 w-6 border-2 border-gray-600 border-t-amber-400"></div>
            <span>Loading...</span>
        </div>
    }
</div>

<!-- Footer -->
<div class="text-center py-4 text-gray-600 text-xs">
    Powered by Speise-Direkt
</div>

@code {
    private List<Menu>? menus;

    protected override async Task OnInitializedAsync()
    {
        menus = await Context.Menus.IgnoreQueryFilters().OrderBy(m => m.Name).ToListAsync();
    }

    private void GoToMenu(Guid menuId) => NavManager.NavigateTo($"/pos/{menuId}");
}
