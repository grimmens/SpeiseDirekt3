@page "/pos/account/overview"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@using SpeiseDirekt.Data
@using SpeiseDirekt.Model
@using SpeiseDirekt3.Resources
@layout PosLayout
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
@inject NavigationManager NavManager
@inject IStringLocalizer<OrderStatusResources> OrderStatusLocalizer

<PageTitle>Mein Konto - Speise-Direkt</PageTitle>

<div class="max-w-2xl mx-auto px-4 py-6 pb-24 lg:pb-6">

    @if (isLoading)
    {
        <div class="flex items-center justify-center py-20">
            <div class="w-10 h-10 border-4 border-gray-200 rounded-full animate-spin" style="border-top-color: #FF8000;"></div>
        </div>
    }
    else if (user == null)
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 text-center">
            <p class="text-gray-600">Du bist nicht angemeldet.</p>
            <a href="/pos/account/login" class="inline-block mt-4 px-5 py-2.5 rounded-full text-white font-semibold text-sm" style="background-color: #FF8000;">Anmelden</a>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Mein Konto</h1>
            <p class="text-sm text-gray-500 mt-1">Verwalte deine persönlichen Daten und sieh dir deine Bestellungen an.</p>
        </div>

        <!-- Profile section -->
        <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 mb-6">
            <div class="flex items-center gap-4 mb-5">
                <div class="w-14 h-14 rounded-full flex items-center justify-center text-white text-xl font-bold" style="background-color: #FF8000;">
                    @GetInitials()
                </div>
                <div class="min-w-0 flex-1">
                    <p class="font-semibold text-gray-900 truncate">@user.Email</p>
                    <p class="text-sm text-gray-500">Kunde</p>
                </div>
            </div>

            <dl class="divide-y divide-gray-100 border-t border-gray-100">
                <div class="flex justify-between py-3 text-sm">
                    <dt class="text-gray-500">Name</dt>
                    <dd class="text-gray-900 font-medium text-right truncate ml-3">@GetFullName()</dd>
                </div>
                <div class="flex justify-between py-3 text-sm">
                    <dt class="text-gray-500">E-Mail</dt>
                    <dd class="text-gray-900 font-medium text-right truncate ml-3">@user.Email</dd>
                </div>
                <div class="flex justify-between py-3 text-sm">
                    <dt class="text-gray-500">Telefonnummer</dt>
                    <dd class="text-gray-900 font-medium text-right truncate ml-3">@(string.IsNullOrEmpty(user.PhoneNumber) ? "—" : user.PhoneNumber)</dd>
                </div>
            </dl>

            <div class="mt-5 flex flex-col gap-2">
                <a href="/pos/account/edit" class="block text-center w-full py-2.5 rounded-full text-white text-sm font-semibold transition-colors hover:opacity-90" style="background-color: #FF8000;">
                    Daten bearbeiten
                </a>
                <form action="/Account/Logout" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="/pos" />
                    <button type="submit" class="w-full py-2.5 rounded-full border-2 text-sm font-semibold transition-colors hover:bg-orange-50" style="border-color: #FF8000; color: #FF8000;">
                        Abmelden
                    </button>
                </form>
            </div>
        </section>

        <!-- Orders section -->
        <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-bold text-gray-900">Bestellungen</h2>
                <span class="text-xs font-medium text-gray-500">@orders.Count gesamt</span>
            </div>

            @if (orders.Count == 0)
            {
                <div class="text-center py-10">
                    <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-gray-100 flex items-center justify-center">
                        <svg class="w-7 h-7 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                        </svg>
                    </div>
                    <p class="text-sm text-gray-500">Du hast noch keine Bestellungen aufgegeben.</p>
                    <a href="/pos" class="inline-block mt-4 px-5 py-2.5 rounded-full text-white font-semibold text-sm" style="background-color: #FF8000;">Jetzt bestellen</a>
                </div>
            }
            else
            {
                <ul class="divide-y divide-gray-100">
                    @foreach (var order in orders)
                    {
                        <li class="py-4 first:pt-0 last:pb-0">
                            <a href="@($"/pos/track/{order.TrackingCode}")" class="flex items-center justify-between gap-3 group">
                                <div class="min-w-0 flex-1">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="font-semibold text-gray-900 text-sm">#@order.OrderNumber</span>
                                        <span class="px-2 py-0.5 text-[11px] font-semibold rounded-full @GetStatusClass(order.Status)">
                                            @GetStatusLabel(order.Status)
                                        </span>
                                    </div>
                                    <p class="text-xs text-gray-500 truncate">
                                        @order.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm") Uhr
                                        @if (order.Menu != null)
                                        {
                                            <span> · @order.Menu.Name</span>
                                        }
                                    </p>
                                    <p class="text-xs text-gray-500">@order.Items.Sum(i => i.Quantity) Artikel</p>
                                </div>
                                <div class="text-right shrink-0">
                                    <p class="font-bold text-gray-900 text-sm">@order.GrandTotal.ToString("C")</p>
                                    <svg class="w-4 h-4 text-gray-400 ml-auto mt-1 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="9 18 15 12 9 6" />
                                    </svg>
                                </div>
                            </a>
                        </li>
                    }
                </ul>
            }
        </section>
    }
</div>

@code {
    private bool isLoading = true;
    private ApplicationUser? user;
    private List<Order> orders = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            NavManager.NavigateTo($"/pos/account/login?returnUrl={Uri.EscapeDataString("/pos/account/overview")}", forceLoad: true);
            return;
        }

        user = await UserManager.GetUserAsync(authState.User);
        if (user == null)
        {
            isLoading = false;
            return;
        }

        if (!string.IsNullOrEmpty(user.Email))
        {
            orders = await DbContext.Orders
                .IgnoreQueryFilters()
                .Include(o => o.Menu)
                .Include(o => o.Items)
                .Where(o => o.CustomerEmail == user.Email)
                .OrderByDescending(o => o.CreatedAt)
                .AsNoTracking()
                .ToListAsync();
        }

        isLoading = false;
    }

    private string GetInitials()
    {
        if (user == null) return "?";
        if (!string.IsNullOrEmpty(user.FirstName))
        {
            var last = !string.IsNullOrEmpty(user.LastName) ? user.LastName[..1] : "";
            return (user.FirstName[..1] + last).ToUpperInvariant();
        }
        var email = user.Email;
        if (string.IsNullOrEmpty(email)) return "?";
        return email[..Math.Min(2, email.Length)].ToUpperInvariant();
    }

    private string GetFullName()
    {
        if (user == null) return "";
        var parts = new[] { user.FirstName, user.LastName }.Where(p => !string.IsNullOrWhiteSpace(p));
        var joined = string.Join(" ", parts);
        return string.IsNullOrEmpty(joined) ? "—" : joined;
    }

    private string GetStatusLabel(OrderStatus status) => OrderStatusLocalizer[status.ToString()];

    private static string GetStatusClass(OrderStatus status) => status switch
    {
        OrderStatus.Draft => "bg-gray-100 text-gray-700",
        OrderStatus.Confirmed => "bg-blue-100 text-blue-700",
        OrderStatus.Preparing => "bg-amber-100 text-amber-700",
        OrderStatus.Ready => "bg-emerald-100 text-emerald-700",
        OrderStatus.Completed => "bg-green-100 text-green-700",
        OrderStatus.Cancelled => "bg-red-100 text-red-700",
        _ => "bg-gray-100 text-gray-700"
    };
}
