@using SpeiseDirekt.Model
@using SpeiseDirekt.ServiceInterface
@inject IPosPaymentService PaymentService
@inject NavigationManager NavManager

<div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 @(isVisible ? "" : "hidden")">
    <div class="bg-white rounded-xl shadow-2xl max-w-lg w-full">
        <div class="bg-gradient-to-r from-blue-900 via-blue-800 to-blue-900 px-6 py-4 rounded-t-xl">
            <h3 class="text-lg font-bold text-white">Checkout</h3>
        </div>
        <div class="p-6 space-y-6">
            @if (Order != null)
            {
                <!-- Order Summary -->
                <div class="space-y-2">
                    <div class="flex justify-between text-sm text-gray-600">
                        <span>Subtotal</span>
                        <span>@Order.SubTotal.ToString("C")</span>
                    </div>
                    <div class="flex justify-between text-sm text-gray-600">
                        <span>Tax</span>
                        <span>@Order.TaxAmount.ToString("C")</span>
                    </div>
                    @if (Order.DiscountAmount > 0)
                    {
                        <div class="flex justify-between text-sm text-green-600">
                            <span>Discount</span>
                            <span>-@Order.DiscountAmount.ToString("C")</span>
                        </div>
                    }
                    <div class="flex justify-between text-lg font-bold text-gray-900 pt-2 border-t border-gray-200">
                        <span>Total</span>
                        <span>@Order.GrandTotal.ToString("C")</span>
                    </div>
                </div>

                <!-- Payment Method -->
                <div>
                    <p class="text-sm font-medium text-gray-700 mb-2">Payment Method</p>
                    <div class="grid grid-cols-2 gap-3">
                        <button class="flex flex-col items-center p-4 rounded-lg border-2 transition-all @(selectedMethod == PosPaymentMethod.Cash ? "border-blue-600 bg-blue-50" : "border-gray-200 hover:border-gray-300")"
                                @onclick="() => selectedMethod = PosPaymentMethod.Cash">
                            <svg class="w-8 h-8 mb-1 @(selectedMethod == PosPaymentMethod.Cash ? "text-blue-600" : "text-gray-400")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                            <span class="text-sm font-medium @(selectedMethod == PosPaymentMethod.Cash ? "text-blue-700" : "text-gray-600")">Cash</span>
                        </button>
                        <button class="flex flex-col items-center p-4 rounded-lg border-2 transition-all @(selectedMethod == PosPaymentMethod.Card ? "border-blue-600 bg-blue-50" : "border-gray-200 hover:border-gray-300")"
                                @onclick="() => selectedMethod = PosPaymentMethod.Card">
                            <svg class="w-8 h-8 mb-1 @(selectedMethod == PosPaymentMethod.Card ? "text-blue-600" : "text-gray-400")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                            </svg>
                            <span class="text-sm font-medium @(selectedMethod == PosPaymentMethod.Card ? "text-blue-700" : "text-gray-600")">Card</span>
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
                        @errorMessage
                    </div>
                }

                <!-- Actions -->
                <div class="flex justify-between items-center pt-4 border-t border-gray-200">
                    <button class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors"
                            @onclick="Close" disabled="@isProcessing">
                        Cancel
                    </button>
                    <button class="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors disabled:opacity-50"
                            @onclick="ProcessPayment" disabled="@isProcessing">
                        @if (isProcessing)
                        {
                            <span>Processing...</span>
                        }
                        else
                        {
                            <span>Pay @Order.GrandTotal.ToString("C")</span>
                        }
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Order? Order { get; set; }
    [Parameter] public EventCallback<PosPayment> OnPaymentComplete { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool isVisible;
    private bool isProcessing;
    private string? errorMessage;
    private PosPaymentMethod selectedMethod = PosPaymentMethod.Cash;

    public void Show()
    {
        isVisible = true;
        isProcessing = false;
        errorMessage = null;
        StateHasChanged();
    }

    private void Close()
    {
        isVisible = false;
        OnCancel.InvokeAsync();
    }

    private async Task ProcessPayment()
    {
        if (Order == null) return;
        isProcessing = true;
        errorMessage = null;

        try
        {
            if (selectedMethod == PosPaymentMethod.Cash)
            {
                var payment = await PaymentService.CreateCashPaymentAsync(Order.Id);
                isVisible = false;
                await OnPaymentComplete.InvokeAsync(payment);
            }
            else
            {
                var baseUrl = NavManager.BaseUri.TrimEnd('/');
                var successUrl = $"{baseUrl}/pos/{Order.MenuId}?orderId={Order.Id}&result=success";
                var cancelUrl = $"{baseUrl}/pos/{Order.MenuId}?orderId={Order.Id}&result=cancel";

                var (_, checkoutUrl) = await PaymentService.CreateStripeCheckoutAsync(
                    Order.Id, successUrl, cancelUrl);

                NavManager.NavigateTo(checkoutUrl, forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }
}
