@using SpeiseDirekt.Model
@inject IJSRuntime JS

<!-- Fullscreen success overlay -->
<div class="fixed inset-0 z-50 flex items-center justify-center @(isVisible ? "" : "hidden")"
     style="background: rgba(0,0,0,0.92); backdrop-filter: blur(12px);">
    <div class="max-w-md w-full mx-4 animate-[scaleIn_0.3s_ease-out]">
        @if (Order != null)
        {
            <!-- Success animation -->
            <div class="text-center mb-6">
                <div class="w-20 h-20 mx-auto mb-4 bg-gradient-to-br from-green-400 to-emerald-500 rounded-full flex items-center justify-center shadow-xl shadow-green-500/30 animate-[bounceIn_0.5s_ease-out]">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <h2 class="text-3xl font-bold text-white mb-1">Order Placed!</h2>
                <p class="text-gray-400">Thank you for your order</p>
            </div>

            <!-- Receipt card -->
            <div class="bg-gray-800 rounded-3xl overflow-hidden shadow-2xl" id="pos-receipt">
                <!-- Order number banner -->
                <div class="bg-gradient-to-r from-amber-500 to-orange-500 px-6 py-5 text-center">
                    <p class="text-amber-100 text-xs uppercase tracking-wider font-semibold mb-1">Your Order Number</p>
                    <p class="text-4xl font-black text-white tracking-wider">@Order.OrderNumber</p>
                </div>

                <!-- Items -->
                <div class="px-6 py-4">
                    @foreach (var item in Order.Items)
                    {
                        <div class="flex justify-between items-center py-2">
                            <div class="flex items-center gap-2">
                                <span class="w-7 h-7 bg-gray-700 rounded-lg flex items-center justify-center text-xs font-bold text-gray-300">@item.Quantity</span>
                                <span class="text-sm text-white">@item.ItemName</span>
                                @if (item.IsComboItem)
                                {
                                    <span class="text-[10px] px-1.5 py-0.5 bg-amber-500/20 text-amber-400 rounded-full font-medium">COMBO</span>
                                }
                            </div>
                            <span class="text-sm text-gray-400 font-medium">@item.LineTotal.ToString("C")</span>
                        </div>
                    }
                </div>

                <!-- Totals -->
                <div class="px-6 py-4 border-t border-gray-700 space-y-1.5">
                    <div class="flex justify-between text-sm text-gray-500">
                        <span>Subtotal</span>
                        <span>@Order.SubTotal.ToString("C")</span>
                    </div>
                    <div class="flex justify-between text-sm text-gray-500">
                        <span>Tax</span>
                        <span>@Order.TaxAmount.ToString("C")</span>
                    </div>
                    @if (Order.DiscountAmount > 0)
                    {
                        <div class="flex justify-between text-sm text-green-400">
                            <span>Discount</span>
                            <span>-@Order.DiscountAmount.ToString("C")</span>
                        </div>
                    }
                    <div class="flex justify-between text-lg font-bold text-white pt-2 border-t border-gray-700">
                        <span>Total Paid</span>
                        <span>@Order.GrandTotal.ToString("C")</span>
                    </div>
                </div>

                @if (Payment != null)
                {
                    <div class="px-6 pb-4 text-center">
                        <span class="text-xs text-gray-500">
                            @Payment.PaymentMethod · @Order.CreatedAt.ToLocalTime().ToString("g")
                        </span>
                    </div>
                }
            </div>

            <!-- Actions -->
            <div class="mt-6 space-y-3">
                <button class="w-full py-4 bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-400 hover:to-orange-400 text-white text-lg font-bold rounded-2xl transition-all active:scale-[0.98] shadow-lg shadow-amber-500/30"
                        @onclick="NewOrder">
                    New Order
                </button>
                <button class="w-full py-3 bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-white text-sm font-medium rounded-2xl transition-all"
                        @onclick="PrintReceipt">
                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                    </svg>
                    Print Receipt
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Order? Order { get; set; }
    [Parameter] public PosPayment? Payment { get; set; }
    [Parameter] public EventCallback OnNewOrder { get; set; }

    private bool isVisible;

    public void Show()
    {
        isVisible = true;
        StateHasChanged();
    }

    private async Task PrintReceipt() => await JS.InvokeVoidAsync("window.print");

    private async Task NewOrder()
    {
        isVisible = false;
        await OnNewOrder.InvokeAsync();
    }
}
