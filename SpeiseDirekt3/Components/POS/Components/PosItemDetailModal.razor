@using SpeiseDirekt.Model

<!-- Backdrop -->
<div class="fixed inset-0 z-50 @(isVisible ? "" : "hidden")"
     @onclick="Close">
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- Bottom sheet (mobile) / Centered modal (desktop) -->
    <div class="absolute inset-x-0 bottom-0 lg:static lg:flex lg:items-center lg:justify-center lg:h-full"
         @onclick:stopPropagation="true">
        <div class="bg-white rounded-t-3xl lg:rounded-2xl lg:max-w-lg w-full max-h-[calc(100vh-60px)] lg:max-h-[90vh] lg:mx-4 flex flex-col overflow-hidden shadow-2xl animate-[slideUp_0.25s_ease-out]">
            @if (Item != null)
            {
                <!-- Close button -->
                <button class="absolute top-3 right-3 z-10 w-8 h-8 bg-white/80 backdrop-blur rounded-full flex items-center justify-center shadow-md"
                        @onclick="Close">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>

                <!-- Scrollable content -->
                <div class="flex-1 overflow-y-auto">
                    <!-- Item image / gradient fallback -->
                    <div class="relative w-full h-[200px] flex-shrink-0" style="background: linear-gradient(135deg, #FF8000 0%, #FFa940 100%);">
                        @if (!string.IsNullOrEmpty(Item.MenuItem?.ImagePath))
                        {
                            <img src="@Item.MenuItem.ImagePath" alt="@Item.ItemName" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <svg class="w-16 h-16 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                </svg>
                            </div>
                        }
                    </div>

                    <!-- Drag handle -->
                    <div class="flex justify-center pt-3 lg:hidden">
                        <div class="w-10 h-1 bg-gray-300 rounded-full"></div>
                    </div>

                    <!-- Item details -->
                    <div class="px-6 pt-4 pb-2">
                        <h2 class="text-2xl font-bold text-gray-900">@Item.ItemName</h2>
                        @if (!string.IsNullOrEmpty(Item.MenuItem?.Description))
                        {
                            <p class="text-gray-500 mt-1 text-sm leading-relaxed">@Item.MenuItem.Description</p>
                        }
                        <p class="text-xl font-bold mt-3" style="color: #FF8000;">@Item.UnitPrice.ToString("C")</p>

                        @if (Item.IsComboItem)
                        {
                            <span class="inline-block mt-2 text-xs px-3 py-1 bg-orange-100 rounded-full font-medium" style="color: #FF8000;">Combo — Menge fixiert</span>
                        }
                    </div>

                    @if (!Item.IsComboItem)
                    {
                        <!-- Divider -->
                        <div class="mx-6 border-t border-gray-200 my-3"></div>

                        <!-- Quantity selector -->
                        <div class="px-6 py-4">
                            <div class="flex items-center justify-center gap-8">
                                <button class="w-12 h-12 rounded-full border-2 flex items-center justify-center transition-all active:scale-95 @(quantity <= 1 ? "border-gray-200 text-gray-300 cursor-not-allowed" : "text-gray-700 hover:bg-orange-50")"
                                        style="@(quantity > 1 ? "border-color: #FF8000;" : "")"
                                        disabled="@(quantity <= 1)"
                                        @onclick="Decrement">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4" />
                                    </svg>
                                </button>
                                <span class="text-2xl font-bold text-gray-900 w-10 text-center">@quantity</span>
                                <button class="w-12 h-12 rounded-full border-2 flex items-center justify-center transition-all active:scale-95 hover:bg-orange-50"
                                        style="border-color: #FF8000; color: #FF8000;"
                                        @onclick="Increment">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <!-- Divider -->
                        <div class="mx-6 border-t border-gray-200 my-1"></div>
                    }
                </div>

                <!-- Sticky bottom actions -->
                <div class="flex-shrink-0 px-6 py-4 bg-white border-t border-gray-100">
                    @if (!Item.IsComboItem)
                    {
                        <button class="w-full py-4 rounded-full font-bold text-white text-lg transition-all active:scale-[0.98]"
                                style="background-color: #FF8000;"
                                @onclick="Confirm">
                            @(isEditing ? "Aktualisieren" : "Zum Warenkorb hinzufügen") — @((Item.UnitPrice * quantity).ToString("C"))
                        </button>
                    }
                    <button class="w-full py-3 text-red-500 font-medium text-center transition-all hover:text-red-600 @(!Item.IsComboItem ? "mt-2" : "")"
                            @onclick="Remove">
                        @(Item.IsComboItem ? "Combo entfernen" : "Aus Bestellung entfernen")
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public OrderItem? Item { get; set; }
    [Parameter] public EventCallback<(Guid ItemId, int Quantity)> OnQuantityChanged { get; set; }
    [Parameter] public EventCallback<Guid> OnRemove { get; set; }

    private bool isVisible;
    private int quantity;
    private bool isEditing => Item?.Quantity > 0;

    public void Show()
    {
        quantity = Item?.Quantity ?? 1;
        isVisible = true;
        StateHasChanged();
    }

    private void Increment() => quantity++;
    private void Decrement() { if (quantity > 1) quantity--; }

    private void Close() => isVisible = false;

    private async Task Confirm()
    {
        if (Item == null) return;
        isVisible = false;
        await OnQuantityChanged.InvokeAsync((Item.Id, quantity));
    }

    private async Task Remove()
    {
        if (Item == null) return;
        isVisible = false;
        await OnRemove.InvokeAsync(Item.Id);
    }
}
