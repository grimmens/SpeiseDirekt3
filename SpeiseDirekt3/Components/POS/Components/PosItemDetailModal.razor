@using SpeiseDirekt.Model

<!-- Item detail / quantity editor overlay -->
<div class="fixed inset-0 z-50 flex items-end sm:items-center justify-center @(isVisible ? "" : "hidden")"
     style="background: rgba(0,0,0,0.85); backdrop-filter: blur(8px);"
     @onclick="Close">
    <div class="max-w-sm w-full mx-4 mb-4 sm:mb-0 animate-[slideUp_0.2s_ease-out]" @onclick:stopPropagation="true">
        @if (Item != null)
        {
            <div class="bg-gray-800 rounded-3xl overflow-hidden shadow-2xl">
                <!-- Item Info -->
                <div class="px-6 pt-6 pb-4">
                    <h3 class="text-xl font-bold text-white mb-1">@Item.ItemName</h3>
                    <p class="text-amber-400 font-semibold">@Item.UnitPrice.ToString("C") each</p>
                    @if (Item.IsComboItem)
                    {
                        <span class="inline-block mt-2 text-xs px-2 py-1 bg-amber-500/20 text-amber-400 rounded-full font-medium">Part of Combo</span>
                    }
                </div>

                <!-- Quantity Selector -->
                <div class="px-6 pb-6">
                    <div class="flex items-center justify-center gap-6">
                        <button class="w-14 h-14 bg-gray-700 hover:bg-gray-600 text-white text-2xl font-bold rounded-2xl transition-all active:scale-95 flex items-center justify-center"
                                @onclick="Decrement">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4" />
                            </svg>
                        </button>
                        <span class="text-4xl font-black text-white w-16 text-center">@quantity</span>
                        <button class="w-14 h-14 bg-amber-500 hover:bg-amber-400 text-white text-2xl font-bold rounded-2xl transition-all active:scale-95 flex items-center justify-center"
                                @onclick="Increment">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
                            </svg>
                        </button>
                    </div>
                    <p class="text-center text-gray-500 text-sm mt-2">Line total: @((Item.UnitPrice * quantity).ToString("C"))</p>
                </div>

                <!-- Actions -->
                <div class="px-6 pb-6 space-y-3">
                    <button class="w-full py-4 bg-gradient-to-r from-blue-500 to-indigo-500 hover:from-blue-400 hover:to-indigo-400 text-white font-bold rounded-2xl transition-all active:scale-[0.98]"
                            @onclick="Confirm">
                        Update Quantity
                    </button>
                    <button class="w-full py-3 bg-red-500/20 hover:bg-red-500/30 text-red-400 font-medium rounded-2xl transition-all"
                            @onclick="Remove">
                        Remove from Order
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public OrderItem? Item { get; set; }
    [Parameter] public EventCallback<(Guid ItemId, int Quantity)> OnQuantityChanged { get; set; }
    [Parameter] public EventCallback<Guid> OnRemove { get; set; }

    private bool isVisible;
    private int quantity;

    public void Show()
    {
        quantity = Item?.Quantity ?? 1;
        isVisible = true;
        StateHasChanged();
    }

    private void Increment() => quantity++;
    private void Decrement() { if (quantity > 1) quantity--; }

    private void Close() => isVisible = false;

    private async Task Confirm()
    {
        if (Item == null) return;
        isVisible = false;
        await OnQuantityChanged.InvokeAsync((Item.Id, quantity));
    }

    private async Task Remove()
    {
        if (Item == null) return;
        isVisible = false;
        await OnRemove.InvokeAsync(Item.Id);
    }
}
