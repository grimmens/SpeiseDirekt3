@using SpeiseDirekt.Model

<!-- Fullscreen combo offer overlay - McDonald's style upsell -->
<div class="fixed inset-0 z-50 flex items-center justify-center @(isVisible ? "" : "hidden")"
     style="background: rgba(0,0,0,0.85); backdrop-filter: blur(8px);">
    <div class="max-w-lg w-full mx-4 animate-[scaleIn_0.2s_ease-out]">
        @if (Combo != null && TriggerItem != null)
        {
            <!-- Header -->
            <div class="bg-gradient-to-r from-amber-500 to-orange-500 rounded-t-3xl px-8 pt-8 pb-6 text-center">
                <div class="w-16 h-16 mx-auto mb-4 bg-white/20 rounded-full flex items-center justify-center">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <h2 class="text-2xl font-bold text-white mb-1">Make it a Combo?</h2>
                <p class="text-amber-100">Save with the @Combo.Name</p>
            </div>

            <!-- Body -->
            <div class="bg-gray-800 px-8 py-6">
                <!-- Price comparison -->
                <div class="flex items-center justify-center gap-4 mb-6">
                    <div class="text-center">
                        <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Item Only</p>
                        <p class="text-2xl font-bold text-gray-400">@TriggerItem.Price.ToString("C")</p>
                    </div>
                    <div class="text-gray-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                        </svg>
                    </div>
                    <div class="text-center">
                        <p class="text-xs text-amber-400 uppercase tracking-wide mb-1">Combo Deal</p>
                        <p class="text-2xl font-bold text-amber-400">@Combo.ComboPrice.ToString("C")</p>
                    </div>
                </div>

                <!-- Included items -->
                <div class="bg-gray-700/50 rounded-xl p-4 mb-6">
                    <p class="text-xs text-gray-400 uppercase tracking-wider mb-3 font-semibold">Combo includes:</p>
                    <div class="space-y-2">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 bg-amber-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            <span class="text-white font-medium">@TriggerItem.Name</span>
                        </div>
                        @foreach (var item in Combo.Items)
                        {
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-green-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                                    <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                    </svg>
                                </div>
                                <span class="text-white font-medium">@item.MenuItem?.Name</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="bg-gray-800 rounded-b-3xl px-8 pb-8 space-y-3">
                <button class="w-full py-4 bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-400 hover:to-orange-400 text-white text-lg font-bold rounded-2xl transition-all active:scale-[0.98] shadow-lg shadow-amber-500/30"
                        @onclick="AcceptCombo">
                    Yes, Make it a Combo!
                </button>
                <button class="w-full py-4 bg-gray-700 hover:bg-gray-600 text-white text-lg font-medium rounded-2xl transition-all active:scale-[0.98]"
                        @onclick="AddItemOnly">
                    Just the @TriggerItem.Name
                </button>
                <button class="w-full py-3 text-gray-500 hover:text-gray-300 text-sm transition-colors"
                        @onclick="Cancel">
                    Cancel
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public MenuCombo? Combo { get; set; }
    [Parameter] public MenuItem? TriggerItem { get; set; }
    [Parameter] public EventCallback<bool> OnResult { get; set; }

    private bool isVisible;

    public void Show()
    {
        isVisible = true;
        StateHasChanged();
    }

    private async Task AcceptCombo()
    {
        isVisible = false;
        await OnResult.InvokeAsync(true);
    }

    private async Task AddItemOnly()
    {
        isVisible = false;
        await OnResult.InvokeAsync(false);
    }

    private void Cancel() => isVisible = false;
}
