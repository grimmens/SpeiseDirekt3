@using SpeiseDirekt.Model

<div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 @(isVisible ? "" : "hidden")">
    <div class="bg-white rounded-xl shadow-2xl max-w-md w-full">
        <div class="bg-gradient-to-r from-orange-500 to-orange-600 px-6 py-4 rounded-t-xl">
            <h3 class="text-lg font-bold text-white">Combo Available!</h3>
        </div>
        <div class="p-6">
            @if (Combo != null)
            {
                <p class="text-gray-700 mb-4">
                    Upgrade to <strong>@Combo.Name</strong> for <strong>@Combo.ComboPrice.ToString("C")</strong>?
                </p>
                @if (!string.IsNullOrEmpty(Combo.Description))
                {
                    <p class="text-sm text-gray-500 mb-4">@Combo.Description</p>
                }
                <div class="mb-4">
                    <p class="text-xs font-medium text-gray-500 uppercase mb-2">Includes:</p>
                    <div class="space-y-1">
                        @foreach (var item in Combo.Items)
                        {
                            <div class="flex items-center gap-2 text-sm text-gray-700">
                                <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                                @item.MenuItem?.Name
                            </div>
                        }
                    </div>
                </div>

                <div class="flex gap-2">
                    <button class="flex-1 px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white font-medium rounded-lg transition-colors"
                            @onclick="AcceptCombo">
                        Add Combo
                    </button>
                    <button class="flex-1 px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg transition-colors"
                            @onclick="AddItemOnly">
                        Item Only
                    </button>
                    <button class="px-4 py-2 text-gray-500 hover:text-gray-700 transition-colors"
                            @onclick="Cancel">
                        Cancel
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public MenuCombo? Combo { get; set; }
    [Parameter] public MenuItem? TriggerItem { get; set; }
    [Parameter] public EventCallback<bool> OnResult { get; set; }

    private bool isVisible;

    public void Show()
    {
        isVisible = true;
        StateHasChanged();
    }

    private async Task AcceptCombo()
    {
        isVisible = false;
        await OnResult.InvokeAsync(true);
    }

    private async Task AddItemOnly()
    {
        isVisible = false;
        await OnResult.InvokeAsync(false);
    }

    private void Cancel()
    {
        isVisible = false;
    }
}
