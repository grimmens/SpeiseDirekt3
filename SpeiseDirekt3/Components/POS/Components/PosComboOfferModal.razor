@using SpeiseDirekt.Model

<!-- Combo offer backdrop -->
@if (isVisible && Combo != null && TriggerItem != null)
{
    <div class="fixed inset-0 z-50 flex items-end sm:items-center justify-center"
         @onclick="Cancel">
        <!-- Dark overlay -->
        <div class="absolute inset-0 bg-black/50 transition-opacity"></div>

        <!-- Modal card: bottom sheet on mobile, centered on desktop -->
        <div class="relative w-full sm:max-w-md sm:mx-4 bg-white rounded-t-2xl sm:rounded-2xl overflow-hidden
                    animate-[slideUp_0.25s_ease-out] sm:animate-[scaleIn_0.2s_ease-out]"
             @onclick:stopPropagation="true">

            <!-- Orange banner strip -->
            <div class="flex items-center gap-3 px-5 py-3" style="background: #FF8000;">
                <!-- Tag/deal icon -->
                <svg class="w-5 h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" />
                </svg>
                <span class="text-white font-bold text-base">Combo Deal</span>
            </div>

            <!-- Main content -->
            <div class="px-5 pt-5 pb-4">
                <!-- Item name + price -->
                <h2 class="text-xl font-bold text-gray-900 mb-1">@Combo.Name</h2>
                <p class="text-lg font-bold mb-2" style="color: #FF8000;">@Combo.ComboPrice.ToString("C")</p>
                <p class="text-sm text-gray-500 mb-5">Füge diese Artikel hinzu und spare!</p>

                <!-- Combo items list -->
                <div class="space-y-3 mb-5">
                    <!-- Trigger item -->
                    <div class="flex items-center gap-3">
                        <div class="w-6 h-6 rounded border-2 flex items-center justify-center flex-shrink-0"
                             style="border-color: #FF8000; background: #FFF7ED;">
                            <svg class="w-4 h-4" style="color: #FF8000;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                            </svg>
                        </div>
                        <span class="text-gray-900 font-medium flex-1">@TriggerItem.Name</span>
                        <span class="text-xs font-semibold text-green-700 bg-green-100 px-2 py-0.5 rounded-full">Enthalten</span>
                    </div>

                    @foreach (var item in Combo.Items)
                    {
                        <div class="flex items-center gap-3">
                            <div class="w-6 h-6 rounded border-2 flex items-center justify-center flex-shrink-0"
                                 style="border-color: #FF8000; background: #FFF7ED;">
                                <svg class="w-4 h-4" style="color: #FF8000;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            <span class="text-gray-900 font-medium flex-1">@item.MenuItem?.Name</span>
                            <span class="text-xs font-semibold text-green-700 bg-green-100 px-2 py-0.5 rounded-full">Enthalten</span>
                        </div>
                    }
                </div>

                <!-- Savings -->
                @{
                    var savings = TriggerItem.Price + Combo.Items.Sum(i => i.MenuItem?.Price ?? 0) - Combo.ComboPrice;
                }
                @if (savings > 0)
                {
                    <p class="text-base font-bold text-green-600 mb-4">Du sparst @savings.ToString("C")!</p>
                }

                <!-- Divider -->
                <hr class="border-gray-200 mb-4" />

                <!-- Actions -->
                <button class="w-full py-3.5 text-white text-base font-bold rounded-full transition-all active:scale-[0.98] shadow-sm mb-3"
                        style="background: #FF8000;"
                        @onclick="AcceptCombo">
                    Combo hinzufügen — @Combo.ComboPrice.ToString("C")
                </button>
                <button class="w-full py-2 text-gray-500 text-sm underline hover:text-gray-700 transition-colors"
                        @onclick="AddItemOnly">
                    Nein danke, nur den Artikel
                </button>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes slideUp {
        from { transform: translateY(100%); }
        to { transform: translateY(0); }
    }
    @@keyframes scaleIn {
        from { transform: scale(0.95); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
</style>

@code {
    [Parameter] public MenuCombo? Combo { get; set; }
    [Parameter] public MenuItem? TriggerItem { get; set; }
    [Parameter] public EventCallback<bool> OnResult { get; set; }

    private bool isVisible;

    public void Show()
    {
        isVisible = true;
        StateHasChanged();
    }

    private async Task AcceptCombo()
    {
        isVisible = false;
        await OnResult.InvokeAsync(true);
    }

    private async Task AddItemOnly()
    {
        isVisible = false;
        await OnResult.InvokeAsync(false);
    }

    private void Cancel() => isVisible = false;
}
