@page "/menu/preview/{id}/{Language?}"
@page "/menu/preview/{id}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager NavManager
@inject IAutomaticTranslator AutomaticTranslator
@inject ILogger<MenuPreviewPage> Logger

@layout MenuLayout

<!-- Content wrapper with top padding to account for fixed banner -->
<div class="">

@if (loading)
    {
        <p>Loading menu...</p>
    }
    else if (menu == null)
    {
        <div class="alert alert-danger mt-5 text-center">
            <h4>Menu not found</h4>
            <p>This menu does not exist or has been deleted.</p>
            <a href="/" class="btn btn-primary">Go Home</a>
        </div>
    }
    else
    {
        <SpeiseDirekt3.Components.Menu.MenuDisplayComponent Menu="menu" CurrentLanguage="currentLanguage" @key="menu" />
    }

</div>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [Parameter] public string? Language { get; set; } = string.Empty;

    private Menu? menu;
    private bool loading = true;
    private MenuLanguage currentLanguage = MenuLanguage.German;

    protected override async Task OnParametersSetAsync()
    {
        if (Guid.TryParse(Id, out var menuId))
        {
            var queryable = DbContext.Menus
                .IgnoreQueryFilters()
                .Include(m => m.Categories)
                .ThenInclude(c => c.MenuItems)
                .AsNoTracking()
                .Where(m => m.Id == menuId);
            menu = await queryable
                .FirstOrDefaultAsync();
            if (menu != null
                && Enum.TryParse<MenuLanguage>(Language, true, out var lang))
            {
                currentLanguage = lang;
                menu = await GetDisplayMenu(menu!, lang);
            }
            else if (menu != null)
            {
                currentLanguage = menu.Language;
            }
        }

        loading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task<Menu?> GetDisplayMenu(Menu menu, MenuLanguage targetLanguage)
    {
        if (menu == null) return null;

        // If current language matches menu language, return original menu
        if (targetLanguage == menu.Language)
        {
            return menu;
        }
        Menu? translatedMenu = null;
        // Need to translate the menu
        translatedMenu = await TranslateMenu(menu, targetLanguage);


        return (translatedMenu ?? menu);
    }

    private async Task<Menu> TranslateMenu(Menu originalMenu, MenuLanguage targetLanguage)
    {
        try
        {
            var translatedMenu = new Menu
            {
                Id = originalMenu.Id,
                Name = await AutomaticTranslator.TranslateTextAsync(originalMenu.Name, targetLanguage, originalMenu.Language),
                Description = await AutomaticTranslator.TranslateTextAsync(originalMenu.Description, targetLanguage, originalMenu.Language),
                Theme = originalMenu.Theme,
                ApplicationUserId = originalMenu.ApplicationUserId,
                Language = targetLanguage,
                Categories = new List<Category>()
            };

            if (originalMenu.Categories != null)
            {
                foreach (var category in originalMenu.Categories)
                {
                    var translatedCategory = await AutomaticTranslator.TranslateCategoryAsync(category, targetLanguage, originalMenu.Language);
                    if (category.MenuItems?.Any() ?? false)
                    {
                        var translatedMenuItems = (await AutomaticTranslator.TranslateMenuItemsAsync(category.MenuItems, targetLanguage, originalMenu.Language)).ToList();
                        foreach(var translatedMenuItem in translatedMenuItems)
                        {
                            translatedMenuItem.Category = translatedCategory;
                            translatedMenuItem.CategoryId = translatedCategory.Id;
                        }
                        translatedCategory.MenuItems = translatedMenuItems;
                    }
                    translatedMenu.Categories.Add(translatedCategory);
                }
            }

            return translatedMenu;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error while translating");
            // Return a copy of the original menu with updated language field
            var fallbackMenu = new Menu
            {
                Id = originalMenu.Id,
                Name = originalMenu.Name,
                Description = originalMenu.Description,
                Theme = originalMenu.Theme,
                ApplicationUserId = originalMenu.ApplicationUserId,
                Language = targetLanguage, // Mark as target language even though not translated
                Categories = originalMenu.Categories?.ToList() ?? new List<Category>()
            };

            return fallbackMenu;
        }
    }
}