@page "/menus"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using SpeiseDirekt.Model
@using SpeiseDirekt.ServiceInterface
@inject ApplicationDbContext DbContext
@inject INotificationService NotificationService
@inject NavigationManager NavManager
@inject IPermissionService PermissionService
@attribute [Authorize]

<PageTitle>Menus - Speise-Direkt</PageTitle>

<!-- Header Section -->
<div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 font-display">Your Menus</h1>
                <p class="mt-2 text-gray-600">Create and manage your restaurant's digital menus</p>
            </div>
            @if (canCreate)
            {
                <div class="mt-4 sm:mt-0">
                    <button class="inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200"
                            @onclick="CreateNewMenu">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                        </svg>
                        Create New Menu
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Content Section -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    @if (menus == null)
    {
        <!-- Loading State -->
        <div class="flex items-center justify-center py-12">
            <div class="flex items-center space-x-3">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                <span class="text-lg text-gray-600">Loading menus...</span>
            </div>
        </div>
    }
    else if (!menus.Any())
    {
        <!-- Empty State -->
        <div class="text-center py-12">
            <div class="mx-auto h-24 w-24 text-gray-400 mb-6">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">No menus yet</h3>
            <p class="text-gray-600 mb-6">Get started by creating your first digital menu</p>
            <button class="inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-200"
                    @onclick="CreateNewMenu">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                Create Your First Menu
            </button>
        </div>
    }
    else
    {
        <!-- Menus Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            @foreach (var menu in menus)
            {
                <a href="@($"menudetail/{menu.Id}")" class="bg-white rounded-lg shadow-sm hover:shadow-md transition-all duration-200 border border-gray-200 overflow-hidden group block">
                    <div class="p-4">
                        <div class="flex items-start justify-between mb-1">
                            <h3 class="text-sm font-bold text-gray-900 group-hover:text-blue-600 transition-colors truncate">
                                @menu.Name
                            </h3>
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 flex-shrink-0 ml-2">
                                @menu.Theme
                            </span>
                        </div>
                        <p class="text-gray-500 text-xs line-clamp-2">@menu.Description</p>
                    </div>
                    @if (canEdit || canDelete)
                    {
                        <div class="px-4 pb-3 flex justify-end gap-2" @onclick:stopPropagation="true">
                            @if (canEdit)
                            {
                                <button class="inline-flex items-center px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium rounded-md transition-colors"
                                        @onclick="() => EditMenu(menu.Id)">
                                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                    </svg>
                                    Edit
                                </button>
                            }
                            @if (canDelete)
                            {
                                <button class="inline-flex items-center px-2 py-1.5 bg-red-600 hover:bg-red-700 text-white text-xs font-medium rounded-md transition-colors"
                                        @onclick="() => DeleteMenu(menu.Id)">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                    </svg>
                                </button>
                            }
                        </div>
                    }
                </a>
            }
        </div>
    }
</div>

@code {
    private List<Menu> menus = new();
    private bool canCreate, canEdit, canDelete;

    protected override async Task OnInitializedAsync()
    {
        canCreate = await PermissionService.HasPermissionAsync(Permission.MenusCreate);
        canEdit = await PermissionService.HasPermissionAsync(Permission.MenusEdit);
        canDelete = await PermissionService.HasPermissionAsync(Permission.MenusDelete);
        menus = await DbContext.Menus.ToListAsync();
    }

    private void CreateNewMenu()
    {
        // Navigate to the "Add" page (no Id)
        NavManager.NavigateTo("/menu/edit");
    }

    private void EditMenu(Guid menuId)
    {
        // Navigate to the "Edit" page for this menu
        NavManager.NavigateTo($"/menu/edit/{menuId}");
    }

    private async Task DeleteMenu(Guid menuId)
    {
        if (!canDelete) return;
        var menu = await DbContext.Menus.FindAsync(menuId);
        if (menu != null)
        {
            var confirm = await NotificationService
                .ShowConfirmation(("Delete", $"Delete \"{menu.Name}\"?"));

            if (confirm)
            {
                DbContext.QRCodes.RemoveRange(DbContext.QRCodes.Where(e => e.MenuId == menu.Id).ToList());
                DbContext.Menus.Remove(menu);
                await DbContext.SaveChangesAsync();

                // Remove from local list to update UI instantly
                menus.Remove(menu);
                StateHasChanged();
            }
        }
    }
}
