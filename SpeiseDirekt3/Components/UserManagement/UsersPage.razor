@page "/users"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using SpeiseDirekt.Model
@using SpeiseDirekt.ServiceInterface
@inject ApplicationDbContext DbContext
@inject IUserIdProvider UserIdProvider
@inject IPermissionService PermissionService
@inject NavigationManager NavManager
@attribute [Authorize]

<PageTitle>Team Management - Speise-Direkt</PageTitle>

<!-- Header -->
<div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 font-display">Team Management</h1>
                <p class="mt-2 text-gray-600">Manage your employees and their permissions</p>
            </div>
            @if (canCreate)
            {
                <div class="mt-4 sm:mt-0">
                    <button class="inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg shadow-md transition-all duration-200"
                            @onclick="InviteUser">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                        </svg>
                        Invite User
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    @if (users == null)
    {
        <div class="flex items-center justify-center py-12">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
            <span class="ml-3 text-gray-600">Loading team...</span>
        </div>
    }
    else if (!users.Any())
    {
        <div class="text-center py-12">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">No team members yet</h3>
            <p class="text-gray-600 mb-6">Invite your first employee to get started</p>
        </div>
    }
    else
    {
        <!-- Role Legend -->
        <div class="flex flex-wrap gap-2 mb-6">
            @foreach (var role in Enum.GetValues<TenantRole>())
            {
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium @GetRoleBadgeClass(role)">
                    @role
                </span>
            }
        </div>

        <!-- Users Table -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
                        @if (canEdit)
                        {
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var user in users)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                @(user.DisplayName ?? "—")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                @(user.ApplicationUser?.Email ?? "—")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @GetRoleBadgeClass(user.Role)">
                                    @user.Role
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (user.IsActive)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Active</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Inactive</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                @user.CreatedAt.ToString("yyyy-MM-dd")
                            </td>
                            @if (canEdit)
                            {
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                    <button class="text-blue-600 hover:text-blue-900 font-medium mr-3"
                                            @onclick="() => EditUser(user.Id)">
                                        Edit
                                    </button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<TenantUser>? users;
    private bool canCreate;
    private bool canEdit;

    protected override async Task OnInitializedAsync()
    {
        canCreate = await PermissionService.HasPermissionAsync(Permission.UsersCreate);
        canEdit = await PermissionService.HasPermissionAsync(Permission.UsersEdit);

        var tenantOwnerId = UserIdProvider.GetUserId();
        users = await DbContext.TenantUsers
            .Include(tu => tu.ApplicationUser)
            .Where(tu => tu.TenantOwnerId == tenantOwnerId)
            .OrderBy(tu => tu.DisplayName)
            .ToListAsync();
    }

    private void InviteUser() => NavManager.NavigateTo("/users/invite");
    private void EditUser(Guid id) => NavManager.NavigateTo($"/users/edit/{id}");

    private static string GetRoleBadgeClass(TenantRole role) => role switch
    {
        TenantRole.GeneralManager => "bg-purple-100 text-purple-800",
        TenantRole.Manager => "bg-blue-100 text-blue-800",
        TenantRole.Cashier => "bg-green-100 text-green-800",
        TenantRole.Employee => "bg-gray-100 text-gray-800",
        TenantRole.Driver => "bg-amber-100 text-amber-800",
        _ => "bg-gray-100 text-gray-800"
    };
}
