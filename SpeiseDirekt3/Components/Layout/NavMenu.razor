@implements IDisposable

@inject NavigationManager NavigationManager

<!-- Brand Header -->
<div class="flex items-center px-6 py-4 border-b border-blue-800">
    <a href="" class="flex items-center space-x-3 text-white hover:text-blue-200 transition-colors duration-200">
        <img src="image/speise-direkt.png" alt="Speise-Direkt Logo" class="h-8 w-8 rounded-lg" />
        <span class="text-xl font-bold font-display">Speise-Direkt</span>
    </a>
</div>



<!-- Navigation Menu -->
<nav class="flex-1 px-4 py-6 space-y-2">
    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="" Match="NavLinkMatch.All">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        Home
    </NavLink>

    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="menus">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        Menus
    </NavLink>

    <AuthorizeView>
        <Authorized>
            <div class="ml-2">
                <MenuTreeNav />
            </div>
        </Authorized>
    </AuthorizeView>

    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="qrcodes">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
        </svg>
        QR Codes
    </NavLink>

    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="analytics">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        Analytics
    </NavLink>

    <!-- POS Section -->
    <div class="border-t border-blue-800 my-4"></div>
    <p class="px-4 text-xs font-semibold text-blue-400 uppercase tracking-wider mb-2">Point of Sale</p>

    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="pos">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        POS
    </NavLink>

    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="orders">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        Orders
    </NavLink>

    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="settings/tax-rates">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Tax Rates
    </NavLink>

    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="settings/discounts">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
        Discounts
    </NavLink>

    <div class="border-t border-blue-800 my-4"></div>

    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="users">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        Team
    </NavLink>

    <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
             href="auth">
        <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        Auth Required
    </NavLink>

    <!-- Divider -->
    <div class="border-t border-blue-800 my-4"></div>

    <!-- User Section -->
    <AuthorizeView>
        <Authorized>
            <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
                     href="Account/Manage">
                <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span class="truncate">@context.User.Identity?.Name</span>
            </NavLink>

            <form action="Account/Logout" method="post" class="mt-2">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                <button type="submit" class="w-full flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-red-600 hover:text-white transition-all duration-200 group">
                    <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                    Logout
                </button>
            </form>
        </Authorized>
        <NotAuthorized>
            <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
                     href="Account/Register">
                <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                </svg>
                Register
            </NavLink>

            <NavLink class="flex items-center px-4 py-3 text-sm font-medium text-blue-100 rounded-lg hover:bg-blue-800 hover:text-white transition-all duration-200 group"
                     href="Account/Login">
                <svg class="mr-3 h-5 w-5 text-blue-300 group-hover:text-white transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                </svg>
                Login
            </NavLink>
        </NotAuthorized>
    </AuthorizeView>
</nav>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

