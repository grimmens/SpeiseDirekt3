@inherits LayoutComponentBase
@attribute [AllowAnonymous]

@using Microsoft.AspNetCore.Authorization

<div class="min-h-screen bg-gray-50 flex flex-col">
    <!-- Top Header Bar -->
    <header class="sticky top-0 z-50 bg-white shadow-sm">
        <div class="flex items-center justify-between px-4 h-14">
            <!-- Left: Logo -->
            <a href="/pos" class="flex items-center gap-1.5 shrink-0">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none">
                    <rect width="24" height="24" rx="6" fill="#FF8000"/>
                    <path d="M7 8h10M7 12h7M7 16h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span class="text-lg font-bold" style="color: #FF8000;">SpeiseDirekt</span>
            </a>

            <!-- Center: Delivery Address -->
            <button class="hidden sm:flex items-center gap-1 px-3 py-1.5 rounded-full bg-gray-100 hover:bg-gray-200 transition-colors max-w-xs truncate text-sm text-gray-700">
                <svg class="w-4 h-4 shrink-0 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                </svg>
                <span class="truncate">Lieferadresse wählen</span>
                <svg class="w-3 h-3 shrink-0 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>

            <!-- Right: Cart Icon -->
            <a href="/pos" class="relative shrink-0 p-2 rounded-full hover:bg-gray-100 transition-colors">
                <svg class="w-6 h-6 text-gray-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1"/>
                    <circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
                </svg>
                <span class="absolute -top-0.5 -right-0.5 flex items-center justify-center w-5 h-5 text-xs font-bold text-white rounded-full" style="background-color: #FF8000;">0</span>
            </a>
        </div>

        <!-- Mobile: Delivery Address (below header on small screens) -->
        <div class="sm:hidden border-t border-gray-100 px-4 py-2">
            <button class="flex items-center gap-1.5 w-full text-left text-sm text-gray-700">
                <svg class="w-4 h-4 shrink-0" style="color: #FF8000;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                </svg>
                <span class="truncate font-medium">Lieferadresse wählen</span>
                <svg class="w-3 h-3 shrink-0 text-gray-400 ml-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto">
        @Body
    </main>

    <!-- Bottom Navigation (mobile only) -->
    <nav class="lg:hidden fixed bottom-0 inset-x-0 z-50 bg-white border-t border-gray-200">
        <div class="flex items-center justify-around h-16">
            <a href="/pos" class="flex flex-col items-center justify-center gap-0.5 w-full py-1 text-gray-500 hover:text-[#FF8000] transition-colors">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span class="text-xs font-medium">Home</span>
            </a>

            <a href="/pos" class="flex flex-col items-center justify-center gap-0.5 w-full py-1 text-gray-500 hover:text-[#FF8000] transition-colors">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <span class="text-xs font-medium">Suche</span>
            </a>

            <a href="/pos/orders" class="flex flex-col items-center justify-center gap-0.5 w-full py-1 text-gray-500 hover:text-[#FF8000] transition-colors">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                </svg>
                <span class="text-xs font-medium">Bestellungen</span>
            </a>

            <a href="/pos/login" class="flex flex-col items-center justify-center gap-0.5 w-full py-1 text-gray-500 hover:text-[#FF8000] transition-colors">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <span class="text-xs font-medium">Profil</span>
            </a>
        </div>
    </nav>

    <!-- Spacer for bottom nav on mobile -->
    <div class="lg:hidden h-16"></div>
</div>
