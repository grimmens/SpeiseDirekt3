@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@implements IDisposable

@if (menus != null)
{
    <div class="space-y-0.5">
        @foreach (var menu in menus)
        {
            var isExpanded = expandedMenuId == menu.Id;
            var isActiveMenu = activeMenuId == menu.Id;

            <!-- Menu Node -->
            <div>
                <div class="flex items-center rounded-lg transition-all duration-200 @(isActiveMenu ? "bg-blue-800 text-white" : "text-blue-100 hover:bg-blue-800/50 hover:text-white")">
                    <button class="flex-shrink-0 p-2 rounded-lg hover:bg-blue-700/50 transition-colors" @onclick="() => ToggleMenu(menu.Id)">
                        <svg class="h-4 w-4 text-blue-300 transition-transform duration-200 @(isExpanded ? "rotate-90" : "")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                    <a href="@($"menu/{menu.Id}")" class="flex-1 py-2 pr-3 text-sm font-medium truncate">
                        @menu.Name
                    </a>
                </div>

                <!-- Children -->
                @if (isExpanded)
                {
                    <div class="ml-4 pl-3 border-l border-blue-700/50 space-y-0.5 mt-0.5">
                        <a href="@($"categories/{menu.Id}")"
                           class="flex items-center px-3 py-1.5 text-xs font-medium rounded-md transition-colors duration-200 @(IsActive($"categories/{menu.Id}") ? "bg-blue-700 text-white" : "text-blue-200 hover:bg-blue-800/50 hover:text-white")">
                            <svg class="mr-2 h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                            </svg>
                            Categories
                        </a>
                        <a href="@($"menuitems/{menu.Id}")"
                           class="flex items-center px-3 py-1.5 text-xs font-medium rounded-md transition-colors duration-200 @(IsActive($"menuitems/{menu.Id}") || IsActive($"MenuItems/") ? "bg-blue-700 text-white" : "text-blue-200 hover:bg-blue-800/50 hover:text-white")">
                            <svg class="mr-2 h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                            Menu Items
                        </a>
                        <a href="@($"allergens/{menu.Id}")"
                           class="flex items-center px-3 py-1.5 text-xs font-medium rounded-md transition-colors duration-200 @(IsActive($"allergens/{menu.Id}") ? "bg-blue-700 text-white" : "text-blue-200 hover:bg-blue-800/50 hover:text-white")">
                            <svg class="mr-2 h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                            Allergens
                        </a>
                        <a href="@($"menu/edit/{menu.Id}")"
                           class="flex items-center px-3 py-1.5 text-xs font-medium rounded-md transition-colors duration-200 @(IsActive($"menu/edit/{menu.Id}") ? "bg-blue-700 text-white" : "text-blue-200 hover:bg-blue-800/50 hover:text-white")">
                            <svg class="mr-2 h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            Settings
                        </a>
                        <a href="@($"menu/preview/{menu.Id}")" target="_blank" rel="noopener noreferrer"
                           class="flex items-center px-3 py-1.5 text-xs font-medium rounded-md text-blue-200 hover:bg-blue-800/50 hover:text-white transition-colors duration-200">
                            <svg class="mr-2 h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                            Preview
                        </a>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private List<Menu>? menus;
    private Guid? expandedMenuId;
    private Guid? activeMenuId;
    private string currentUrl = "";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        menus = await db.Menus.OrderBy(m => m.Name).ToListAsync();
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        ResolveActiveMenu();
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        ResolveActiveMenu();
        StateHasChanged();
    }

    private void ResolveActiveMenu()
    {
        activeMenuId = null;

        if (menus == null) return;

        // Try to extract a menu ID from common URL patterns
        foreach (var menu in menus)
        {
            var id = menu.Id.ToString();
            if (currentUrl.Contains(id, StringComparison.OrdinalIgnoreCase))
            {
                activeMenuId = menu.Id;
                expandedMenuId = menu.Id;
                return;
            }
        }
    }

    private void ToggleMenu(Guid menuId)
    {
        expandedMenuId = expandedMenuId == menuId ? null : menuId;
    }

    private bool IsActive(string path)
    {
        return currentUrl.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
