@page "/settings/tax-rates"
@using Microsoft.AspNetCore.Authorization
@using SpeiseDirekt.Model
@using SpeiseDirekt.ServiceInterface
@inject ITaxService TaxService
@inject INotificationService NotificationService
@inject IPermissionService PermissionService
@inject NavigationManager NavManager
@attribute [Authorize(Policy = PolicyNames.TenantStaff)]

<PageTitle>Tax Rates</PageTitle>

<div class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <h1 class="text-3xl font-bold text-gray-900 font-display">Tax Rates</h1>
        <p class="mt-1 text-gray-600">Configure tax rates for POS orders.</p>
    </div>
</div>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Add Form -->
    @if (canCreate)
    {
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Add Tax Rate</h2>
            <div class="flex flex-col sm:flex-row gap-3">
                <input type="text" @bind="newName" placeholder="Name (e.g. Standard VAT)"
                       class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none text-sm" />
                <input type="number" @bind="newRate" step="0.01" min="0" max="100" placeholder="Rate %"
                       class="w-32 px-3 py-2 border border-gray-300 rounded-lg focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none text-sm" />
                <label class="flex items-center gap-2 text-sm text-gray-700">
                    <input type="checkbox" @bind="newIsDefault" class="rounded border-gray-300" />
                    Default
                </label>
                <button class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors"
                        @onclick="AddTaxRate">Add</button>
            </div>
        </div>
    }

    <!-- List -->
    @if (taxRates == null)
    {
        <div class="flex items-center justify-center py-12">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var rate in taxRates)
            {
                <div class="bg-white rounded-xl border border-gray-200 p-4 flex items-center justify-between">
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="font-medium text-gray-900">@rate.Name</span>
                            @if (rate.IsDefault)
                            {
                                <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Default</span>
                            }
                        </div>
                        <p class="text-sm text-gray-500">@((rate.Rate * 100).ToString("0.##"))%</p>
                    </div>
                    <div class="flex gap-2">
                        @if (canEdit && !rate.IsDefault)
                        {
                            <button class="text-sm text-blue-600 hover:text-blue-800 font-medium"
                                    @onclick="() => SetDefault(rate.Id)">Set Default</button>
                        }
                        @if (canDelete)
                        {
                            <button class="text-sm text-red-600 hover:text-red-800"
                                    @onclick="() => Delete(rate)">Delete</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<TaxRate>? taxRates;
    private string newName = "";
    private decimal newRate;
    private bool newIsDefault;
    private bool canCreate, canEdit, canDelete;

    protected override async Task OnInitializedAsync()
    {
        canCreate = await PermissionService.HasPermissionAsync(Permission.TaxRatesCreate);
        canEdit = await PermissionService.HasPermissionAsync(Permission.TaxRatesEdit);
        canDelete = await PermissionService.HasPermissionAsync(Permission.TaxRatesDelete);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        taxRates = await TaxService.GetAllAsync();
    }

    private async Task AddTaxRate()
    {
        if (string.IsNullOrWhiteSpace(newName)) return;
        await TaxService.CreateAsync(newName, newRate / 100m, newIsDefault);
        newName = "";
        newRate = 0;
        newIsDefault = false;
        await LoadAsync();
    }

    private async Task SetDefault(Guid id)
    {
        await TaxService.SetDefaultAsync(id);
        await LoadAsync();
    }

    private async Task Delete(TaxRate rate)
    {
        var confirm = await NotificationService.ShowConfirmation(("Delete", $"Delete \"{rate.Name}\"?"));
        if (confirm)
        {
            await TaxService.DeleteAsync(rate.Id);
            await LoadAsync();
        }
    }
}
